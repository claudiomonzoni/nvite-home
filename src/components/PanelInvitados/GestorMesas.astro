---
import { Icon } from "astro-icon/components";

interface MesaData {
  id: number;
  usuarioId: number;
  nombre: string;
  capacidad: number;
}

interface InvitadoData {
  id: number;
  uuid: string | null;
  usuarioId: number;
  nombre: string;
  pases: string;
  mesa: string | number | null;
  mesaId: number | null;
  confirmado: boolean;
  noAsiste: boolean;
  vip?: boolean;
  InvitacionEnviada?: boolean;
  tipoInvitacion?: string | null;
}

interface Props {
  mesas: MesaData[];
  invitados: InvitadoData[];
  nombreEvento?: string | null;
  fechaEvento?: Date | string | null;
}

const { mesas, invitados, nombreEvento = "Mi Evento", fechaEvento = "" } = Astro.props;

// Filtrar los invitados que no tienen mesa asignada (y que asistirán o están pendientes)
const invitadosSinAsignar = invitados.filter(
  (inv) => !inv.mesaId && !inv.noAsiste
);

// Calcular estadísticas de gestión de mesas
const totalMesas = mesas.length;

const statsMesas = mesas.map((mesa) => {
  const invMesa = invitados.filter((inv) => inv.mesaId === mesa.id && !inv.noAsiste);
  const pasosOcupados = invMesa.reduce((sum, inv) => sum + parseInt(inv.pases || "0", 10), 0);
  return {
    id: mesa.id,
    capacidad: mesa.capacidad,
    pasosOcupados,
    sobrecupo: pasosOcupados > mesa.capacidad,
    completa: pasosOcupados >= mesa.capacidad,
  };
});

const totalCapacidad = statsMesas.reduce((sum, m) => sum + m.capacidad, 0);
const totalOcupado = statsMesas.reduce((sum, m) => sum + m.pasosOcupados, 0);
const espaciosDisponibles = Math.max(0, totalCapacidad - totalOcupado);
const mesasConSobrecupo = statsMesas.filter((m) => m.sobrecupo).length;
const mesasCompletas = statsMesas.filter((m) => m.completa && !m.sobrecupo).length;
---

<div
  class="gestor-mesas-container"
  data-nombre-evento={nombreEvento}
  data-fecha-evento={fechaEvento ? new Date(fechaEvento).toISOString().split('T')[0] : ""}
  data-invitados={JSON.stringify(invitados)}
  data-mesas={JSON.stringify(mesas)}
>
  <!-- Resumen de gestión de mesas -->
  <div class="resumen-pases-bar">
    <div class="resumen-item">
      <span class="resumen-icon"><Icon name="mdi:checkbox-multiple-outline" size={24} /></span>
      <span class="num">{totalMesas}</span>
      <span class="lbl">Mesas creadas</span>
    </div>
    {
      mesasConSobrecupo > 0 && (
        <div class="resumen-item sobrecupo">
          <span class="resumen-icon"><Icon name="mdi:alert-outline" size={24} /></span>
          <span class="num">{mesasConSobrecupo}</span>
          <span class="lbl">{mesasConSobrecupo === 1 ? 'Mesa con sobrecupo' : 'Mesas con sobrecupo'}</span>
        </div>
      )
    }
    <div class="resumen-item completa">
      <span class="resumen-icon"><Icon name="mdi:calendar-check" size={24} /></span>
      <span class="num">{mesasCompletas}</span>
      <span class="lbl">{mesasCompletas === 1 ? 'Mesa completa' : 'Mesas completas'}</span>
    </div>
    <div class="resumen-item disponible">
      <span class="resumen-icon"><Icon name="mdi:crop-free" size={24} /></span>
      <span class="num">{espaciosDisponibles}</span>
      <span class="lbl">Espacios disponibles</span>
    </div>
  </div>

  <div class="gestor-layout">
    <!-- Panel Izquierdo: Lista de Mesas -->
    <div class="mesas-grid-column">
      <div class="section-header">
        <h2>Distribución de Mesas ({mesas.length})</h2>
        <div class="header-actions-group">
          <button id="btn-exportar-mesas" class="btn-excel-sm" title="Exportar Distribución de Mesas a Excel">
            <Icon name="mdi:microsoft-excel" size={18} />
            <span>Descargar Excel</span>
          </button>
          <button id="btn-nueva-mesa" class="btn-primary-sm">
            <Icon name="mdi:table-plus" size={18} />
            <span>Agregar Mesa</span>
          </button>
        </div>
      </div>

      <div class="mesas-grid">
        {
          mesas.length > 0 ? (
            mesas.map((mesa) => {
              // Filtrar los invitados asignados a esta mesa
              const invitadosMesa = invitados.filter(
                (inv) => inv.mesaId === mesa.id && !inv.noAsiste
              );

              // Calcular ocupación de pases
              const pasesConfirmados = invitadosMesa
                .filter((i) => i.confirmado)
                .reduce((sum, i) => sum + parseInt(i.pases || "0", 10), 0);

              const pasesPendientes = invitadosMesa
                .filter((i) => !i.confirmado)
                .reduce((sum, i) => sum + parseInt(i.pases || "0", 10), 0);

              const pasesTotales = pasesConfirmados + pasesPendientes;
              const libres = Math.max(0, mesa.capacidad - pasesTotales);
              const esExcedido = pasesTotales > mesa.capacidad;
              const esLlena = pasesTotales === mesa.capacidad;

              // Porcentajes para la barra visual
              const pctConf = Math.min(100, (pasesConfirmados / mesa.capacidad) * 100);
              const pctPend = Math.min(100 - pctConf, (pasesPendientes / mesa.capacidad) * 100);

              return (
                <div class={`mesa-card ${esExcedido ? "excedido" : ""} ${esLlena ? "llena" : ""}`} data-mesa-id={mesa.id}>
                  <div class="mesa-card-header">
                    <div>
                      <h3 class="mesa-name">{mesa.nombre}</h3>
                      <span class="mesa-capacity">
                        Capacidad: {mesa.capacidad} asientos
                      </span>
                    </div>
                    <div class="mesa-header-actions">
                      <button
                        class="btn-mesa-edit"
                        data-action-edit-mesa
                        data-id={mesa.id}
                        data-nombre={mesa.nombre}
                        data-capacidad={mesa.capacidad}
                        title="Editar Mesa"
                      >
                        <Icon name="mdi:pencil" size={16} />
                      </button>
                      <button
                        class="btn-mesa-delete"
                        data-action-delete-mesa
                        data-id={mesa.id}
                        data-nombre={mesa.nombre}
                        title="Eliminar Mesa"
                      >
                        <Icon name="mdi:delete" size={16} />
                      </button>
                    </div>
                  </div>

                  <!-- Barra de Ocupación Visual -->
                  <div class="mesa-progress-container">
                    <div class="mesa-progress-bar">
                      <div
                        class="progress-fill confirmed"
                        style={`width: ${pctConf}%`}
                      />
                      <div
                        class="progress-fill pending"
                        style={`width: ${pctPend}%`}
                      />
                    </div>
                    <div class="occupancy-row">
                      <span class="occupancy-text">
                        Ocupación: {pasesTotales} / {mesa.capacidad}
                      </span>
                      {esExcedido && (
                        <span class="excedido-badge" title="La ocupación supera la capacidad de la mesa">
                          <Icon name="mdi:alert-circle" size={14} />
                          <span>Sobrecupo (+{pasesTotales - mesa.capacidad})</span>
                        </span>
                      )}
                    </div>
                  </div>

                  <!-- Invitados en esta mesa -->
                  <ul class="mesa-guests-list">
                    {invitadosMesa.length > 0 ? (
                      invitadosMesa.map((guest) => (
                        <li class="mesa-guest-item">
                          <div class="guest-info">
                            <span
                              class={`guest-dot ${
                                guest.confirmado ? "confirmed" : "pending"
                              }`}
                            />
                            <span class="guest-name">{guest.nombre}</span>
                          </div>
                          <div class="guest-details">
                            <span class="guest-passes">
                              {guest.pases} pases
                            </span>
                            <select
                              class="select-mesa-assign mini"
                              data-guest-id={guest.id}
                              data-current-mesa-id={mesa.id}
                            >
                              <option value="0">Desasignar</option>
                              {mesas.map((m) => (
                                <option value={m.id} selected={m.id === mesa.id}>
                                  {m.nombre}
                                </option>
                              ))}
                            </select>
                          </div>
                        </li>
                      ))
                    ) : (
                      <li class="mesa-empty-placeholder">Mesa vacía</li>
                    )}
                    {libres > 0 && (
                      <li class="mesa-free-space-item">
                        <Icon name="mdi:circle-outline" size={14} />
                        <span>{libres} espacios disponibles</span>
                      </li>
                    )}
                  </ul>
                </div>
              );
            })
          ) : (
            <div class="empty-mesas-state">
              <Icon name="mdi:table-furniture" size={48} />
              <p>No has creado ninguna mesa para tu evento.</p>
              <p class="sub">Usa el botón "Agregar Mesa" para comenzar a organizar.</p>
            </div>
          )
        }
      </div>
    </div>

    <!-- Panel Derecho: Pool de Invitados Sin Asignar -->
    <div class="unassigned-pool-column">
      <div class="section-header">
        <h2>Sin Asignar ({invitadosSinAsignar.length})</h2>
      </div>

      <div class="unassigned-list-container">
        {
          invitadosSinAsignar.length > 0 ? (
            <ul class="unassigned-guests-list">
              {invitadosSinAsignar.map((guest) => (
                <li class="unassigned-guest-item">
                  <div class="guest-main">
                    <span
                      class={`guest-dot ${
                        guest.confirmado ? "confirmed" : "pending"
                      }`}
                    />
                    <div>
                      <span class="guest-name">{guest.nombre}</span>
                      <span class="guest-sub">
                        {guest.pases} pases •{" "}
                        {guest.confirmado ? "Confirmado" : "Pendiente"}
                      </span>
                    </div>
                  </div>
                  <div class="guest-action">
                    <select
                      class="select-mesa-assign"
                      data-guest-id={guest.id}
                      data-current-mesa-id="0"
                    >
                      <option value="0" selected>
                        Asignar mesa...
                      </option>
                      {mesas.map((m) => (
                        <option value={m.id}>{m.nombre}</option>
                      ))}
                    </select>
                  </div>
                </li>
              ))}
            </ul>
          ) : (
            <div class="all-assigned-placeholder">
              <Icon name="mdi:checkbox-marked-circle-outline" size={36} />
              <p>Todos tus invitados confirmados y pendientes ya están asignados a una mesa.</p>
            </div>
          )
        }
      </div>
    </div>
  </div>

  <!-- Modal Crear Mesa -->
  <dialog id="modal-mesa-crear" class="admin-dialog">
    <div class="dialog-content">
      <h2>Agregar Nueva Mesa</h2>
      <form id="form-mesa-crear">
        <label>
          Nombre de la mesa
          <input type="text" name="nombre" required placeholder="ej: Mesa de Novios, Mesa 4" />
        </label>
        <label>
          Capacidad de asientos
          <input type="number" name="capacidad" required min="1" max="100" value="10" />
        </label>
        <div class="dialog-actions">
          <button type="button" class="btn-cancel" data-close-mesa-modal>Cancelar</button>
          <button type="submit" class="btn-submit">Crear Mesa</button>
        </div>
      </form>
    </div>
  </dialog>

  <!-- Modal Editar Mesa -->
  <dialog id="modal-mesa-editar" class="admin-dialog">
    <div class="dialog-content">
      <h2>Editar Mesa</h2>
      <form id="form-mesa-editar">
        <input type="hidden" name="id" id="edit-mesa-id" />
        <label>
          Nombre de la mesa
          <input type="text" name="nombre" id="edit-mesa-nombre" required />
        </label>
        <label>
          Capacidad de asientos
          <input type="number" name="capacidad" id="edit-mesa-capacidad" required min="1" max="100" />
        </label>
        <div class="dialog-actions">
          <button type="button" class="btn-cancel" data-close-mesa-modal>Cancelar</button>
          <button type="submit" class="btn-submit">Guardar Cambios</button>
        </div>
      </form>
    </div>
  </dialog>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Modales de Mesa
    const crearMesaDialog = document.getElementById("modal-mesa-crear") as HTMLDialogElement;
    const editarMesaDialog = document.getElementById("modal-mesa-editar") as HTMLDialogElement;
    const btnNuevaMesa = document.getElementById("btn-nueva-mesa");
    const closeBtns = document.querySelectorAll("[data-close-mesa-modal]");

    btnNuevaMesa?.addEventListener("click", () => {
      crearMesaDialog.showModal();
    });

    closeBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        crearMesaDialog.close();
        editarMesaDialog.close();
      });
    });

    // 2. Crear Mesa (POST)
    const formCrear = document.getElementById("form-mesa-crear") as HTMLFormElement;
    formCrear?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(formCrear);
      const payload = {
        nombre: formData.get("nombre"),
        capacidad: formData.get("capacidad")
      };

      try {
        const res = await fetch("/api/mesas.json", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (res.ok && data.success) {
          location.reload();
        } else {
          alert(data.error || "Error al crear la mesa.");
        }
      } catch (err) {
        console.error(err);
        alert("Error de conexión al servidor.");
      }
    });

    // 3. Llenar Editar Mesa y PATCH
    const editBtns = document.querySelectorAll("[data-action-edit-mesa]") as NodeListOf<HTMLButtonElement>;
    editBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const id = btn.getAttribute("data-id") || "";
        const nombre = btn.getAttribute("data-nombre") || "";
        const capacidad = btn.getAttribute("data-capacidad") || "";

        (document.getElementById("edit-mesa-id") as HTMLInputElement).value = id;
        (document.getElementById("edit-mesa-nombre") as HTMLInputElement).value = nombre;
        (document.getElementById("edit-mesa-capacidad") as HTMLInputElement).value = capacidad;

        editarMesaDialog.showModal();
      });
    });

    const formEditar = document.getElementById("form-mesa-editar") as HTMLFormElement;
    formEditar?.addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(formEditar);
      const payload = {
        id: formData.get("id"),
        nombre: formData.get("nombre"),
        capacidad: formData.get("capacidad")
      };

      try {
        const res = await fetch("/api/mesas.json", {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload)
        });
        const data = await res.json();
        if (res.ok && data.success) {
          location.reload();
        } else {
          alert(data.error || "Error al editar la mesa.");
        }
      } catch (err) {
        console.error(err);
        alert("Error de conexión.");
      }
    });

    // 4. Eliminar Mesa (DELETE)
    const deleteBtns = document.querySelectorAll("[data-action-delete-mesa]") as NodeListOf<HTMLButtonElement>;
    deleteBtns.forEach((btn) => {
      btn.addEventListener("click", async () => {
        const id = btn.getAttribute("data-id");
        const nombre = btn.getAttribute("data-nombre");

        if (confirm(`¿Quieres eliminar la mesa "${nombre}"?\n\nLos invitados asignados a esta mesa volverán a la lista de "Sin Asignar".`)) {
          try {
            const res = await fetch("/api/mesas.json", {
              method: "DELETE",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ id })
            });
            const data = await res.json();
            if (res.ok && data.success) {
              location.reload();
            } else {
              alert(data.error || "Error al eliminar.");
            }
          } catch (err) {
            console.error(err);
            alert("Error de conexión.");
          }
        }
      });
    });

    // 5. Asignar Invitado a Mesa (PATCH del Invitado)
    const assignSelects = document.querySelectorAll(".select-mesa-assign") as NodeListOf<HTMLSelectElement>;
    assignSelects.forEach((select) => {
      select.addEventListener("change", async () => {
        const guestId = select.getAttribute("data-guest-id");
        const mesaId = select.value === "0" ? null : parseInt(select.value, 10);

        try {
          const res = await fetch(`/api/${guestId}.json`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ mesaId })
          });
          const data = await res.json();
          if (res.ok && data.success) {
            location.reload();
          } else {
            alert(data.error || "Error al asignar mesa.");
            // Revertir selección
            select.value = select.getAttribute("data-current-mesa-id") || "0";
          }
        } catch (err) {
          console.error(err);
          alert("Error de red.");
          select.value = select.getAttribute("data-current-mesa-id") || "0";
        }
      });
    });

    // 6. Exportar a Excel (SheetJS)
    const loadSheetJS = () => {
      return new Promise<void>((resolve, reject) => {
        if ((window as any).XLSX) {
          resolve();
          return;
        }
        const script = document.createElement("script");
        script.src = "https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js";
        script.onload = () => resolve();
        script.onerror = () => reject(new Error("No se pudo cargar la librería de Excel."));
        document.head.appendChild(script);
      });
    };

    const btnExportarMesas = document.getElementById("btn-exportar-mesas") as HTMLButtonElement | null;
    btnExportarMesas?.addEventListener("click", async () => {
      if (!btnExportarMesas) return;
      try {
        btnExportarMesas.disabled = true;
        const originalText = btnExportarMesas.innerHTML;
        btnExportarMesas.innerHTML = "<span>Generando...</span>";
        
        await loadSheetJS();
        
        const container = document.querySelector(".gestor-mesas-container");
        const invitados = JSON.parse(container?.getAttribute("data-invitados") || "[]");
        const nombreEvento = container?.getAttribute("data-nombre-evento") || "evento";
        const fechaEvento = container?.getAttribute("data-fecha-evento") || "";
        
        interface ExportRow {
          Nombre: string;
          Pases: number;
          Estado: string;
          Mesa: string;
        }
        
        const formattedData: ExportRow[] = invitados.map((inv: any) => {
          let estado = "Sin confirmar";
          if (inv.noAsiste) estado = "No asiste";
          else if (inv.confirmado) estado = "Confirmado";
          
          return {
            Nombre: String(inv.nombre || ""),
            Pases: parseInt(String(inv.pases || "0"), 10),
            Estado: estado,
            Mesa: String(inv.mesa || "Sin asignar")
          };
        });
        
        // Ordenar: mesas agrupadas, al final Sin asignar
        formattedData.sort((a, b) => {
          if (a.Mesa !== "Sin asignar" && b.Mesa === "Sin asignar") return -1;
          if (a.Mesa === "Sin asignar" && b.Mesa !== "Sin asignar") return 1;
          if (a.Mesa !== "Sin asignar" && b.Mesa !== "Sin asignar") {
            return a.Mesa.localeCompare(b.Mesa);
          }
          return a.Nombre.localeCompare(b.Nombre);
        });
        
        const XLSX = (window as any).XLSX;
        const worksheet = XLSX.utils.json_to_sheet(formattedData);
        const workbook = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(workbook, worksheet, "Distribución de Mesas");
        
        // Ajustar ancho de columnas automáticamente
        const maxLen = formattedData.reduce((acc, row) => {
          acc.Nombre = Math.max(acc.Nombre, row.Nombre.length);
          acc.Estado = Math.max(acc.Estado, row.Estado.length);
          acc.Mesa = Math.max(acc.Mesa, row.Mesa.length);
          return acc;
        }, { Nombre: 10, Pases: 6, Estado: 15, Mesa: 15 });
        
        worksheet["!cols"] = [
          { wch: maxLen.Nombre + 3 },
          { wch: 10 },
          { wch: maxLen.Estado + 3 },
          { wch: maxLen.Mesa + 3 }
        ];
        
        const sanitizedNombre = nombreEvento.toLowerCase().replace(/[^a-z0-9]/g, "-").replace(/-+/g, "-").replace(/^-|-$/g, "");
        const fileName = `mesas-${sanitizedNombre}-${fechaEvento || new Date().toISOString().split("T")[0]}.xlsx`;
        
        XLSX.writeFile(workbook, fileName);
        
        btnExportarMesas.innerHTML = originalText;
        btnExportarMesas.disabled = false;
      } catch (err) {
        console.error(err);
        alert("Ocurrió un error al descargar el Excel.");
        btnExportarMesas.innerHTML = "<span>Descargar Excel</span>";
        btnExportarMesas.disabled = false;
      }
    });
  });
</script>

<style lang="scss">
  @use "../../estilos/_variables.scss" as *;

  .gestor-mesas-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 1rem;
    font-family: $fuenteA;

    @include cel {
      padding: 0 1rem;
      margin-left: -1rem;
      margin-right: -1rem;
      gap: 1.5rem;
    }
  }

  .resumen-pases-bar {
    display: flex;
    gap: 2rem;
    width: 100%;
    padding: 1rem ;
    background: white;
    border-radius: $radio;
    flex-wrap: wrap;
    @extend .sombra;

    @include cel {
      gap: 1rem;
      padding: 0.5rem;
    }
  }

  .resumen-icon{
    display: flex;
    color: currentColor;
  }
  .resumen-item {
    flex: 1;
    display: flex;
    min-width: 150px;
    text-align: center;
    justify-content: center;
    align-items: center;
    padding: 1rem;
    border-right: 1px solid rgba($primario, 0.1);
    font-size: clamp(0.9rem, 1vw, 1rem);
    gap: 0.75rem;
    color: $primario;
    
    &:last-child {
      border-right: none;
    }

    .dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .num {
      font-size: clamp(1.3rem, 1.5vw, 1.5rem);
      font-weight: bold;
    }

    &.confirmado {
      .dot { background-color: #4caf50; }
      .num { color: #4caf50; }
    }

    &.pendiente {
      .dot { background-color: #ffb74d; }
      .num { color: #ffb74d; }
    }

    &.libre {
      .dot { background-color: #9ca3af; }
      .num { color: #9ca3af; }
    }

    &.total {
      .num {
        color: $primario;
      }
      .lbl {
        color: $gris;
      }
    }

    @include cel {
      min-width: calc(50% - 1rem);
      padding: .5rem 0.2rem;
      border-right: none;
      border-bottom: 1px solid rgba($primario, 0.1);
      gap: .5rem;
      flex-direction: column;
      &:nth-last-child(-n + 2) {
        border-bottom: none;
      }
    }
  }

  .gestor-layout {
    display: grid;
    grid-template-columns: 3fr 1.2fr;
    gap: 2rem;
    align-items: start;

    @include cel {
      grid-template-columns: 1fr;
    }
  }

  .section-header {
