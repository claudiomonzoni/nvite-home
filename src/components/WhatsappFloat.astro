<style>
/* Estado inicial: oculto y no interactuable */
.whatsapp-float {
  position: fixed;
  bottom: 24px;
  right: 20px;
  z-index: 9999;
  display: flex;
  align-items: center;
  gap: 8px;
  background-color: #6E8F70;
  color: #ffffff;
  padding: 12px 20px;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  box-shadow: 0 4px 16px rgba(37, 211, 102, 0.12);
  transform: translateY(12px) scale(0.98);
  opacity: 0;
  pointer-events: none;
  transition: transform 320ms cubic-bezier(.22,.9,.46,1),
              opacity 320ms cubic-bezier(.22,.9,.46,1),
              box-shadow 220ms ease;
}

.whatsapp-float.visible {
  opacity: 1;
  transform: translateY(0) scale(1);
  pointer-events: auto;
  box-shadow: 0 8px 28px rgba(37, 211, 102, 0.28);
}

.whatsapp-float:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 12px 36px rgba(37, 211, 102, 0.32);
}

.whatsapp-float svg {
  width: 20px;
  height: 20px;
  fill: #ffffff;
  flex-shrink: 0;
}

.whatsapp-float span {
  display: inline-block;
}

/* Small screens: slightly smaller and closer to edge */
@media (max-width: 420px) {
  .whatsapp-float {
    right: 12px;
    padding: 10px 14px;
    font-size: 13px;
  }
}
</style>

<script>
(() => {
  const THRESHOLD = 800;
  let ticking = false;

  if ((window as any).__whatsappFloatInit) return;
  (window as any).__whatsappFloatInit = true;

  function queryEl() {
    return document.querySelector('.whatsapp-float');
  }

  function update() {
    try {
      const el = queryEl();
      if (!el) return;
      el.classList.toggle('visible', window.scrollY > THRESHOLD);
    } catch (e) {
      console.error('WhatsappFloat update error:', e);
    }
  }

  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        update();
        ticking = false;
      });
      ticking = true;
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  document.addEventListener('astro:after-swap', () => setTimeout(update, 50));
  window.addEventListener('popstate', () => setTimeout(update, 50));
  window.addEventListener('hashchange', () => setTimeout(update, 50));
  document.addEventListener('visibilitychange', () => setTimeout(update, 50));

  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    update();
  } else {
    document.addEventListener('DOMContentLoaded', update);
  }
})();
</script>
