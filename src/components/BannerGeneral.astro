---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";

interface Props {
  encabezado: string;
  texto: string;
  tema?: string;
  icono?: string;
  izquierda?: boolean;
  urlImagen?: string;
  margenAbajo?: boolean;
  valorBoton?: string;
}

const {
  encabezado,
  texto,
  tema,
  icono,
  izquierda,
  urlImagen,
  margenAbajo,
  valorBoton,
  ...rest
} = Astro.props;

const temaBase =
  typeof tema === "string"
    ? tema.split(/\s+/).find((t) => ["primario", "secundario", "terciario"].includes(t)) ?? "primario"
    : "primario";

const estilosTema = {
  primario: {
    "--banner-bg": "linear-gradient(43deg, #dae3ea 10%, #656A8D 80%)",
    "--banner-bg-mobile": "linear-gradient(43deg, #656A8D 10%, #EB8686 80%)",
    "--banner-svg": "#ffce95",
    "--banner-heading": "#ffce95",
    "--banner-text": "#ffffff",
  },
  secundario: {
    "--banner-bg": "linear-gradient(43deg, #dae3ea 10%, rgb(255, 247, 233) 80%)",
    "--banner-bg-mobile": "linear-gradient(43deg, #dae3ea 10%, rgb(255, 247, 233) 80%)",
    "--banner-svg": "#EB8686",
    "--banner-heading": "#656A8D",
    "--banner-text": "#656A8D",
  },
  terciario: {
    "--banner-bg": "linear-gradient(83deg, #a2a4ba 10%, #656A8D 60%)",
    "--banner-bg-mobile": "linear-gradient(123deg, #a2a4ba 10%, #656A8D 60%)",
    "--banner-svg": "#d65e5e",
    "--banner-heading": "#fff6f0",
    "--banner-text": "#ffffff",
  },
};

const imagen = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/home/gale/*.{jpeg,jpg,png,gif,webp}"
);
if (urlImagen && !imagen[urlImagen])
  throw new Error(`"${urlImagen}" no existe wey, checale bien"`);
const imagenCargada = urlImagen ? imagen[urlImagen]() : null;
---

<div
  id="banner"
  class:list={["flex", tema, { margenAbajo: margenAbajo }]}
  style={estilosTema[temaBase as keyof typeof estilosTema]}
  {...rest}
>
  <div class="contenido flex">
    <div class="bande">
      <Icon name={icono} size={40} />
      <h2 set:html={encabezado} />
      <p set:html={texto} />
      <slot />
    </div>
  </div>
  {imagenCargada && (
    <div class:list={["imagen", { izq: izquierda }]}>
      <Image src={imagenCargada} alt={encabezado} />
    </div>
  )}
</div>

<style lang="scss">
  @use "../estilos/_variables.scss" as *;
  .margenAbajo {
    margin-bottom: $margen;
  }

  #banner {
    margin-top: $margen;
    border-radius: $radio;
    margin-bottom: $margen-min;
    background: var(--banner-bg, linear-gradient(43deg, $terciario 10%, $primario 80%));
    color: var(--banner-text, $gris);
    gap: 0;
  }
  h2 {
    font-size: clamp(2.2rem, 3.5vw, 3.5rem);
    color: var(--banner-heading, $gris) !important;
  }
  p {
    color: var(--banner-text, $gris);
  }
  .izq {
    order: 1 !important;
    @include cel {
      order: 0 !important;
    }
  }
  .contenido {
    align-items: center;
    justify-content: center;
    order: 1;
    flex: 1 0 60%;
    padding: $margen;
    @include cel {
      padding: $margen-cel;
    }
  }
  .imagen {
    order: 0;
    flex: 1 0 40%;
    z-index: 200;
    img {
      width: auto;
      height: auto;
      @extend .imagenFuera;
      position: relative;
    }
    @include cel {
      img {
        width: 100%;
        height: 100%;
        aspect-ratio: 9/13;
        object-fit: cover;
      }
    }
  }
  .primario {
    background: var(--banner-bg, linear-gradient(43deg, $terciario 10%, $primario 80%));
    svg {
      color: var(--banner-svg, $fondo) !important;
      fill: var(--banner-svg, $fondo) !important;
    }
    h2 {
      color: var(--banner-heading, $fondo) !important;
    }
    p {
      color: var(--banner-text, white);
    }
    @include cel {
      background: var(--banner-bg-mobile, linear-gradient(43deg, $primario 10%, $secundario 80%));
    }
  }
  .secundario {
    svg {
      color: var(--banner-svg, $secundario) !important;
      fill: var(--banner-svg, $secundario) !important;
    }
    h2{
      color: var(--banner-heading, $primario) !important;
    }
    color: var(--banner-text, $primario);
    background: var(--banner-bg, linear-gradient(43deg, $terciario 10%, rgb(255, 247, 233) 80%));
  }
  .terciario {
    svg {
      fill: var(--banner-svg, $acento) !important;
      color: var(--banner-svg, $acento) !important;
    }

    h2 {
      color: var(--banner-heading, $fondoGlobal) !important;
    }

    background: var(--banner-bg, linear-gradient(83deg, #a2a4ba 10%, $primario 60%));
    color: var(--banner-text, #fff);
    @include cel {
      background: var(--banner-bg-mobile, linear-gradient(123deg, #a2a4ba 10%, $primario 60%));
    }
  }

  // Cel

  @include cel {
    .imagen,
    .contenido {
      flex: 1 0 100%;
    }
  }

</style>
