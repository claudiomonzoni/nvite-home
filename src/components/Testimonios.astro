---
import "swiper/css";
import "swiper/css/pagination";
import "swiper/css/navigation";

const reviews = [
  {
    name: "Berenice Jimenez",
    image: "https://lh3.googleusercontent.com/a-/ALV-UjXmoVWw6nsrNe1efzBInej_NPnj5jfaEl9zibKvXPgy2Gg4JquS=s50-c-rp-mo-br100",
    text: "Nos hicieron unas invitaciones para boda y nos encantaron, están súper lindas y practicas, me las entregaron muy rápido y tienen muy buen estilo. Los súper recomiendo✨🤩 100/10",
    rating: 5
  },
  {
    name: "Chucho González",
    image: "https://lh3.googleusercontent.com/a-/ALV-UjXo4JUASbjgi76039aHG8vnbYGWYwWbLFXzi159ciP60lmteUQK=s50-c-rp-mo-br100",
    text: "Estuvieron excelentes, a todos mis amigos les encantaron, saludos",
    rating: 5
  },
  {
    name: "Gabriela Mon",
    image: "https://lh3.googleusercontent.com/a/ACg8ocJzrSiEJc6JE_GX_v4va33Nf9VLdrofwZIeBBK15bn1V2SE_w=s50-c-rp-mo-br100",
    text: "Bellísimas invitaciones 😍 fueron enviadas para nuestra boda y encantaron, súper profesionales en toda la atención",
    rating: 5
  },
  {
    name: "Wen Jira",
    image: "https://lh3.googleusercontent.com/a/ACg8ocIG-V7JGfPOyLHWPrYHFfou9TneSnSewqb2aHe_5dr47n9EvA=s50-c-rp-mo-br100",
    text: "Fueron atentos, rápidos y siempre dispuestos. Las invitaciones fueron hermosas y funcionales, facilitando el control de invitados. Sin duda, los volverías a contratar.",
    rating: 5
  }
];

const schemaReviews = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Invitaciones Digitales Nvitaciones",
  "image": "https://nvitaciones.com/invitaciones-digitales-cover-nvitacines-cel.webp",
  "description": "Organiza a tus invitados con invitaciones digitales. Envía por WhatsApp, confirma asistencias y gestiona tus invitados fácilmente con Nvitaciones.",
  "sku": "nvitaciones-digitales",
  "brand": {
    "@type": "Brand",
    "name": "Nvitaciones"
  },
  "offers": {
    "@type": "AggregateOffer",
    "priceCurrency": "MXN",
    "lowPrice": "450",
    "highPrice": "1500",
    "offerCount": "3"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "reviewCount": reviews.length.toString()
  },
  "review": reviews.map(review => ({
    "@type": "Review",
    "author": {
      "@type": "Person",
      "name": review.name
    },
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": review.rating.toString(),
      "bestRating": "5"
    },
    "reviewBody": review.text
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaReviews)} />

<section class="testimonios">
  <div class="testimonios__container">
    <h2 class="testimonios__title">Lo que dicen nuestros clientes</h2>
    <p>Testimonios tomados de nuestros clientes en Google Reviews</p>

    <div class="swiper testimonios-swiper">
      <div class="swiper-wrapper">
        {reviews.map(review => (
          <div class="swiper-slide">
            <div class="testimonios__card">
              <img
                src={review.image}
                alt={`Cliente ${review.name}`}
                class="testimonios__image"
                loading="lazy"
                decoding="async"
              />
              <h3 class="testimonios__name">{review.name}</h3>
              <p class="testimonios__text">
                "{review.text}"
              </p>
            </div>
          </div>
        ))}
      </div>

      <div class="swiper-pagination"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-button-next"></div>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../estilos/_variables.scss" as *;

  .testimonios {
    padding: 5rem 0;
    background: linear-gradient(180deg, $fondoGlobal, $terciario);
    h2 {
      margin-bottom: 0;
    }
    p {
      text-align: center;
      margin-bottom: 2rem;
    }

    &__container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    &__title {
      font-size: 2.5rem;
      font-weight: bold;
      text-align: center;
      margin-bottom: 3rem;
      color: $acento;
    }

    &__card {
      background-color: $fondoGlobal;
      padding: 2rem;
      border-radius: $radio;
      //  @extend .sombra;
    }

    &__image {
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      margin: 0 auto 1rem;
      display: block;
    }

    &__name {
      font-size: 1.25rem;
      text-align: center;
      color: $primario;
    }

    &__text {
      text-align: center;
      margin-top: 1rem;
      color: $primario;
    }
    @include cel {
      padding: 2rem 0 5rem 0;
    }
  }

  :global(.swiper-button-next),
  :global(.swiper-button-prev) {
    color: $acento;
    top: 2rem;

    &::after {
      font-size: 1.3rem; // Reduce el tamaño del ícono
      font-weight: bold;
    }

    @include cel {
      display: none;
    }
  }

  :global(.swiper-button-next) {
    right: 1rem; // Ajustado de la posición original
  }

  :global(.swiper-button-prev) {
    left: 1rem; // Ajustado de la posición original
  }

  :global(.swiper-pagination-bullet-active) {
    background: $acento;
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, Pagination, Autoplay } from "swiper/modules";
  function initializeTestimonios() {
    // Destruir instancia existente si hay alguna
    const swiperElement = document.querySelector(".testimonios-swiper");
    const existingSwiper = swiperElement && (swiperElement as any).swiper;
    if (existingSwiper) {
      existingSwiper.destroy(true, true);
    }

    // Crear nueva instancia
    new Swiper(".testimonios-swiper", {
      modules: [Navigation, Pagination, Autoplay],
      slidesPerView: 1,
      spaceBetween: 30,
      loop: true,
      autoplay: {
        delay: 4000,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
        dynamicBullets: true, // Hace que los bullets sean más dinámicos
        dynamicMainBullets: 3, // Muestra 3 bullets principales
      },
      navigation: {
        nextEl: ".swiper-button-next",
        prevEl: ".swiper-button-prev",
      },
      breakpoints: {
        640: {
          slidesPerView: 2,
        },
        1024: {
          slidesPerView: 3,
        },
      },
    });
  }

  // Inicializar en transiciones de página
  document.addEventListener("astro:page-load", initializeTestimonios);

  // Inicializar si el documento ya está cargado
  if (document.readyState === "complete") {
    initializeTestimonios();
  }
</script>
