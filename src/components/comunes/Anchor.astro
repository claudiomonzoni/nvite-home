---
import { Icon } from "astro-icon/components";

interface Props {
  id?: string;
  clases?: string;
  conBorde?: boolean;
  redondo?: boolean;
  sombra?: boolean;
  tema?: string;
  url: string;
  texto?: string;
  target?: string;
  icono?: string;
}
const { clases, conBorde, redondo, sombra, tema, url, texto, icono, ...rest } =
  Astro.props;
---

<a
  href={url}
  class:list={[
    "btn",
    clases,
    tema,
    { "con-borde": conBorde, redondo: redondo, sombra: sombra },
  ]}
  {...rest}
>
  {icono && <Icon name={icono} size={22} />}
  {texto}
</a>

<style lang="scss">
  @use "../../estilos/bodas/_variables.scss" as *;

  @mixin liga($conBorde, $redondo, $sombra) {
    margin: $margen-min 0;
    color: white !important;
    font-family: $txt;
    background: var(--acento);
    padding: 0.7rem $margen-cel;
    svg {
      vertical-align: middle;
    }
    img {
      max-width: 1.5rem !important;
      height: auto;
      vertical-align: middle;
      margin-right: 0.5rem;
    }
    @if $conBorde {
      border: 1px solid var(--acento);
      background: var(--secundario);
      opacity: 0.8;
      color: var(--primario) !important;
    }
    @if $redondo {
      border-radius: $radio;
    }
    @if $sombra {
      filter: drop-shadow(0.4rem 0.4rem .3rem var(--primario));
    }
    @include cel {
      display: block;
      width: 100%;
      max-width: 70%;
      box-sizing: border-box;
      margin-left: 0;
      margin-right: 0;
    }
  }

  .btn {
    @include liga(false, false, false);
  }
  .con-borde {
    @include liga(true, null, null);
  }
  .redondo {
    @include liga(null, true, null);
  }
  .sombra {
    @include liga(null, null, true);
  }
</style>
