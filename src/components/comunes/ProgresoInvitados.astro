---
import { db, Invitados, Usuario, eq } from "astro:db";
import Anchor from "./Anchor.astro";

interface Props {
    porcentajeMostrarInvitados: number;
    mostrarSiempre: boolean;
    frase: string;
    email: string;
    labels?: {
        confirmed?: string;
        passesConfirmed?: string;
        of?: string;
        btnConfirm?: string;
        allReady?: string;
    };
}

const {
    porcentajeMostrarInvitados,
    mostrarSiempre,
    frase,
    email,
    labels = {},
} = Astro.props;

const l = {
    confirmed: labels.confirmed || "de invitados han confirmado",
    passesConfirmed: labels.passesConfirmed || "pases confirmados",
    of: labels.of || "de",
    btnConfirm: labels.btnConfirm || "Confirmar",
    allReady:
        labels.allReady || "¡Que empiece la fiesta, estamos todos listos!",
};

let totalPases = 0;
let pasesConfirmados = 0;
let porcentajeConfirmados = 0;
let mostrarComponente = false;

try {
    // 1. Obtener el usuario por email
    const users = await db
        .select()
        .from(Usuario)
        .where(eq(Usuario.email, email));

    if (users.length > 0) {
        const userId = users[0].id;

        // 2. Obtener los invitados de ese usuario
        const invitados = await db
            .select()
            .from(Invitados)
            .where(eq(Invitados.usuarioId, userId));

        // 3. Calcular totales
        totalPases = invitados.reduce((sum, invitado) => {
            const pases = parseInt(invitado.pases) || 0;
            return sum + pases;
        }, 0);

        pasesConfirmados = invitados.reduce((sum, invitado) => {
            if (invitado.confirmado && !invitado.noAsiste) {
                const pases = parseInt(invitado.pases) || 0;
                return sum + pases;
            }
            return sum;
        }, 0);

        porcentajeConfirmados = totalPases > 0
            ? Math.round((pasesConfirmados / totalPases) * 100)
            : 0;

        mostrarComponente = mostrarSiempre || porcentajeConfirmados >= porcentajeMostrarInvitados;
    }
} catch (error) {
    console.error("Error al calcular progreso de invitados en SSR:", error);
}
---

{mostrarComponente && (
    <div id="progreso-invitados" class="progreso-invitados">
        <div class="contenido">
            <h2 id="frase-titulo">
                {porcentajeConfirmados === 100 ? l.allReady : frase}
            </h2>
            <p class="porcentaje">
                <span class="numero">{porcentajeConfirmados}%</span>
                <span class="texto">{l.confirmed}</span>
            </p>
            <div class="estadisticas">
                <div class="barra-progreso">
                    <div class="barra" style={`--progress: ${porcentajeConfirmados}%`}></div>
                </div>
                <p class="detalles">
                    <span class="confirmados">{pasesConfirmados}</span>
                    {l.of}
                    <span class="total">{totalPases}</span>
                    {l.passesConfirmed}
                </p>
            </div>
            <Anchor
                url={"#Confirmacion-comun"}
                id="confirmacion-btn-progreso"
                icono="solar:check-read-outline"
                clases={"large"}
                neumorfismo={true}
                redondo={false}
                sombra={false}
                tema={"primario"}
                texto={l.btnConfirm}
            />
        </div>
    </div>
)}
