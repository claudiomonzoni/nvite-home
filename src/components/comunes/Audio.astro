---
interface Props {
    src: string;
    labels?: {
        listen?: string;
    };
}
const { src, labels = {} } = Astro.props;

const l = {
    listen: labels.listen || "Canción del evento",
};

import { Icon } from 'astro-icon/components';
//import {Anchor} from './Anchor.astro';
---

<audio id="audioInvitacion" loop style="display: none;">
    <source src={src} type="audio/mpeg" />
</audio>

<section id="fixedAudio" class="fixed-bottom-bar hidden">
    <ul>
        <li>
            <a href="#asistencia" class="action-btn" aria-label="Confirmar ">
                <span class="icon-circle">
               <Icon name="mdi:check-all" />
                </span>
                <span>confirma</span>
            </a>
        </li>
        <li>
            <button id="toggleAudioBtn" class="action-btn" aria-label="Reproducir/Pausar música">
                <span class="icon-circle">
                <Icon name="mdi:play" id="icon-play" />
                <Icon name="mdi:pause" id="icon-pause" style="display: none;" />
                </span>
                <span id="audioText">canción del evento</span>
            </button>
        </li>
    </ul>
</section>

<script>
    const audio = document.getElementById("audioInvitacion") as HTMLAudioElement;
    const fixedAudio = document.getElementById("fixedAudio");
    const toggleBtn = document.getElementById("toggleAudioBtn");
    const iconPlay = document.getElementById("icon-play");
    const iconPause = document.getElementById("icon-pause");
    const audioText = document.getElementById("audioText");
    
    let isPlaying = false;

    // Escuchar el evento personalizado para iniciar el audio
    window.addEventListener("iniciarInvitacion", () => {
        if (audio) {
            audio.play().then(() => {
                isPlaying = true;
                updateUI();
            }).catch((error) => {
                console.log(
                    "No se pudo reproducir el audio automáticamente:",
                    error,
                );
            });
        }
    });

    if (toggleBtn && audio) {
        toggleBtn.addEventListener("click", () => {
            if (isPlaying) {
                audio.pause();
                isPlaying = false;
            } else {
                audio.play();
                isPlaying = true;
            }
            updateUI();
        });

        audio.addEventListener("play", () => {
            isPlaying = true;
            updateUI();
        });

        audio.addEventListener("pause", () => {
            isPlaying = false;
            updateUI();
        });
    }

    function updateUI() {
        if (!iconPlay || !iconPause || !audioText) return;
        if (isPlaying) {
            iconPlay.style.display = "none";
            iconPause.style.display = "block";
            // audioText.textContent = "Pausar"; // Removido para igualar el diseño fijo de Figma
        } else {
            iconPlay.style.display = "block";
            iconPause.style.display = "none";
            // audioText.textContent = "Reproducir"; // Removido para igualar el diseño fijo de Figma
        }
    }

    // Manejar Scroll
    function handleScroll() {
        if (!fixedAudio) return;
        if (window.scrollY > 500) {
            fixedAudio.classList.add("visible");
        } else {
            fixedAudio.classList.remove("visible");
        }
    }

    window.addEventListener("scroll", handleScroll);
    
    // Verificación inicial por si la página carga ya habiendo scroleado
    handleScroll();
</script>

<style lang="scss">
   // @use "../../estilos/bodas/_variables.scss" as *;

    .fixed-bottom-bar {
        position:fixed;
        bottom: 0;
        left: 50%;
        transform: translateX(-50%) translateY(50px);
        z-index: 1000;
        width: 100%;
        
        /* Efecto Glass */
        background-color: var(--glass-bg, rgba(227, 202, 192, 0.4));
        backdrop-filter: var(--glass-blur, blur(10px));
        -webkit-backdrop-filter: var(--glass-blur, blur(10px));
        
        padding: 9px 18px;
        transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        opacity: 0;
        pointer-events: none;
    }

    .fixed-bottom-bar.visible {
        opacity: 1;
        pointer-events: auto;
        transform: translateX(-50%) translateY(0);
    }

    .fixed-bottom-bar ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        gap: 20px;
        align-items: center;
    }

    .fixed-bottom-bar li {
        flex-wrap: wrap;
        display: flex;
        align-items: center;
        a{
            display: flex;
        }
    }

    .icon-circle {
        width: 21px;
        height: 21px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: currentColor;
    }

    .action-btn {
        display: flex;
        flex-direction: row;
        flex-wrap: nowrap;
        align-items: center;
        white-space: nowrap;
        gap: 8px;
        background: none;
        border: none;
        color: #765b4a;
        font-family: "Montserrat", sans-serif;
        font-size: 13px;
        font-weight: 400;
        cursor: pointer;
        text-decoration: none;
        padding: 0;
        transition: opacity 0.2s ease, transform 0.1s ease;
    }

    .action-btn:hover {
        opacity: 0.8;
    }

    .action-btn:active {
        transform: scale(0.95);
    }

    .action-btn span:not(.icon-circle) {
        white-space: nowrap;
    }
</style>
