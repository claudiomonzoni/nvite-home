---
interface Props {
    src: string;
    labels?: {
        listen?: string;
        confirm?: string;
        playSong?: string;
        pauseSong?: string;
        ariaConfirm?: string;
        ariaPlayPause?: string;
    };
}
const { src, labels = {} } = Astro.props;

const l = {
    listen: labels.listen || "Canción del evento",
    confirm: labels.confirm || "Confirma",
    playSong: labels.playSong || "Reproducir canción",
    pauseSong: labels.pauseSong || "Pausar canción",
    ariaConfirm: labels.ariaConfirm || "Confirmar asistencia",
    ariaPlayPause: labels.ariaPlayPause || "Reproducir/Pausar música",
};

import { Icon } from 'astro-icon/components';
---

<audio id="audioInvitacion" loop style="display: none;">
    <source src={src} type="audio/mpeg" />
</audio>

<section
    id="fixedAudio"
    class="fixed-bottom-bar hidden"
    data-play-text={l.playSong}
    data-pause-text={l.pauseSong}
>
    <ul>
        <li id="confirmLi" style="transition: opacity 0.3s ease, max-width 0.4s ease; overflow: hidden; max-width: 200px; opacity: 1;">
            <a href="#Confirmacion-comun" class="action-btn" aria-label={l.ariaConfirm}>
                <span class="icon-circle">
               <Icon name="mdi:check-all" />
                </span>
                <span>{l.confirm}</span>
            </a>
        </li>
        <li>
            <button id="toggleAudioBtn" class="action-btn" aria-label={l.ariaPlayPause}>
                <span class="icon-circle">
                <Icon name="mdi:play" id="icon-play" />
                <Icon name="mdi:pause" id="icon-pause" style="display: none;" />
                </span>
                <span id="audioText">{l.playSong}</span>
            </button>
        </li>
    </ul>
</section>

<script>
    const audio = document.getElementById("audioInvitacion") as HTMLAudioElement;
    const fixedAudio = document.getElementById("fixedAudio");
    const toggleBtn = document.getElementById("toggleAudioBtn");
    const iconPlay = document.getElementById("icon-play");
    const iconPause = document.getElementById("icon-pause");
    const audioText = document.getElementById("audioText");
    const confirmLi = document.getElementById("confirmLi");

    // Leer textos localizados desde data attributes
    const playText = fixedAudio?.dataset.playText || "Reproducir canción";
    const pauseText = fixedAudio?.dataset.pauseText || "Pausar canción";
    
    let isPlaying = false;

    // Escuchar el evento personalizado para iniciar el audio
    window.addEventListener("iniciarInvitacion", () => {
        if (audio) {
            audio.play().then(() => {
                isPlaying = true;
                updateUI();
            }).catch((error) => {
                console.log(
                    "No se pudo reproducir el audio automáticamente:",
                    error,
                );
            });
        }
    });

    if (toggleBtn && audio) {
        toggleBtn.addEventListener("click", () => {
            if (isPlaying) {
                audio.pause();
                isPlaying = false;
            } else {
                audio.play();
                isPlaying = true;
            }
            updateUI();
        });

        audio.addEventListener("play", () => {
            isPlaying = true;
            updateUI();
        });

        audio.addEventListener("pause", () => {
            isPlaying = false;
            updateUI();
        });
    }

    function updateUI() {
        if (!iconPlay || !iconPause || !audioText) return;
        if (isPlaying) {
            iconPlay.style.display = "none";
            iconPause.style.display = "block";
            audioText.textContent = pauseText;
        } else {
            iconPlay.style.display = "block";
            iconPause.style.display = "none";
            audioText.textContent = playText;
        }
    }

    // Manejar Scroll + ocultar "Confirma" al 60% del alto total
    function handleScroll() {
        if (!fixedAudio) return;

        const scrolled = window.scrollY > 500;
        fixedAudio.classList.toggle("visible", scrolled);

        // Ocultar el anchor "Confirma" cuando se ha recorrido el 90% de la página
        if (confirmLi) {
            const scrollPercent = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
            const shouldHide = scrollPercent >= 0.9;
            confirmLi.style.opacity = shouldHide ? "0" : "1";
            confirmLi.style.maxWidth = shouldHide ? "0" : "200px";
            confirmLi.style.pointerEvents = shouldHide ? "none" : "";
        }
    }

    window.addEventListener("scroll", handleScroll);
    
    // Verificación inicial por si la página carga ya habiendo scroleado
    handleScroll();
</script>
