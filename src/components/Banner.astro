<style lang="scss">
  @use "../estilos/_variables.scss" as *;
  #titulo {
    text-align: center;
    margin-top: $margen;
    flex: 1 0 100%;
    h2 {
      font-weight: 600;
      color: $primario;
    }
  }
  h2 {
    color: $acento;
    font-size: clamp(2.2rem, 1.5vw, 2.7vw);
    position: relative;
  }
  small {
    color: $gris;
  }
  b {
    color: $primario;
    text-decoration: underline;
    text-underline-offset: 5px;
    text-decoration-thickness: 0.9px;
  }
  .precio {
    display: flex;
    gap: 1rem;
    flex-direction: column;
    padding-bottom: 1rem;
    border-bottom: solid 1px $terciario;
    font-weight: bolder;
    color: $primario;
    font-size: clamp(1.5rem, 1.2vw, 1.5vw);
    small {
      color: $primario;
      font-weight: normal;
      font-size: clamp(0.6rem, 0.7rem, 1rem);
    }
  }
  .banner {
    display: flex;
    flex-wrap: wrap;
  }
  .der,
  .izq {
    display: flex;
    justify-content: center;
    @include cel {
      flex: 1 0 100%;
    }
  }
  .der {
    flex-wrap: wrap;
    flex: 1 0 70%;
    @tableta_land {
      flex: 1 0 80%;
    }
  }
  .izq {
    flex: 1 0 30%;
    width: 100px;
    align-items: center;
    @tableta_land {
      flex: 1 0 20%;
    }
  }
  .bande {
    display: flex;
    margin: $margen-cel 0 $margen;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
  }
  .bandeDestacada {
    width: 80%;
    padding: $margen-min;
    @include cel {
      width: 100%;
    }
  }
  .lista {
    flex: 1;
    max-width: min(100%, 50ch);
    justify-content: center;
    align-self: center;
    padding: 2rem $margen-cel;
    @include hd {
      padding: 0 3rem;
    }
    li {
      font-size: clamp(1rem, 0.8rem, 1rem);
    }
    li:nth-of-type(3n) {
      padding-bottom: 8px;
    }
    a {
      justify-self: flex-start;
      svg {
        vertical-align: middle;
      }
    }

    @include cel {
      flex: 1 0 100%;
      border-right: none;

      position: relative;
      a {
        width: 100%;
      }
    }
    #lux {
      max-width: 90%;
    }
  }
  #lux {
    h3 {
      padding-bottom: $margen-min;
      border: solid 1px rgba($primario, 0.4);
      border-radius: $radio;
      text-align: center;
      padding: 10px $margen-min;
      margin-bottom: $margen-min;
    }
    li {
      padding-bottom: 8px;
      p {
      }
    }
  }
  .destacada {
    display: flex;
    background: white;
    background: linear-gradient(
      0deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 1) 100%
    );
    border-radius: $radio;
    padding: 1rem;
    @extend .sombra;

    @include cel {
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 1) 100%
      );
    }
  }
  #masvendido {
    border-bottom: solid 2px $primario;
    position: absolute;
    background: rgb(255, 255, 255, 0.4);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(3px);
    @extend .sombra;
    border-radius: $radio;
    color: $primario;
    font-size: clamp(0.8rem, 0.6vw, 1vw);
    padding: 0 0.5rem;
    transform: rotate(-5deg);
    right: 0;
    top: 35%;
  }
  .conteBtn {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    @include cel {
      gap: 0.2rem;
    }
  }
  .conteBtn > * {
    min-width: fit-content;
    text-align: center;
    flex: 1;
  }
  ul {
    padding: 1rem 0;
    li::marker {
      color: $secundario;
    }
  }
  @include cel {
    .izq,
    .der {
      flex: 1 0 100%;
    }
  }

  .azulBG {
    border-radius: $radio;
    background:
      url("/fondo-nvite-caracteristicas-banner.png") no-repeat,
      linear-gradient(43deg, $fondoGlobal 30%, $terciario 100%) no-repeat;
    background-position:
      center left,
      top left;
    background-size: 50%, 100%;
    margin-bottom: $margen-min;
    @include cel {
      background:
        url("/fondo-nvite-caracteristicas-banner.png") no-repeat,
        linear-gradient(0deg, $fondoGlobal 0%, $terciario 100%) no-repeat;
      background-position: center bottom;
      background-size: 120%;
    }
  }
  sup {
    font-size: 0.7rem;
  }
</style>
