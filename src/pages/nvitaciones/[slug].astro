---
// Importaciones principales
const slug = Astro.params.slug ?? "";
import { getProductPrice } from "../../js/cart";
import { calculateDeliveryDate } from "../../js/utils";
import { Image } from "astro:assets";
import { getEntry } from "astro:content";
import { Icon } from "astro-icon/components";

// Componentes
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import Nav from "../../components/Nav.astro";
import Btn from "../../components/Btn.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import SocialShare from "../../components/SocialShare.astro";
import RelatedProducts from "../../components/Pagos/RelatedProducts.astro";
import Testimonios from "../../components/Testimonios.astro";
import PreviewModal from "../../components/PreviewModal.astro";
import BeneficioCard from "../../components/BeneficioCard.astro";

const panelTestimonials = [
  {
    stars: 5,
    text: "Estuvieron excelentes, a todos mis amigos les encantaron",
    author: "— Chucho González / Zihuatanejo Gro.",
  },
  {
    stars: 5,
    text: "La invitación LUX quedó perfecta y todos confirmaron, ¡muy recomendable!",
    author: "— Sofía Martínez / Morelia, Mich.",
  },
  {
    stars: 5,
    text: "Me encantó el diseño LUX y fueron muy atentos.",
    author: "— Andrea P. / Guadalajara, Jal.",
  },
  {
    stars: 5,
    text: "Me ayudaron durante todo el proceso desde la compra hasta que mande mi primer invitación.",
    author: "— Fátima Osorio / CDMX",
  },
];

function getTestimonialIndex(seed: string | undefined, length: number) {
  const normalized = seed || "default";
  return (
    Math.abs(
      normalized
        .split("")
        .reduce((acc, char) => acc * 31 + char.charCodeAt(0), 0),
    ) % length
  );
}

const testimonial =
  panelTestimonials[getTestimonialIndex(slug, panelTestimonials.length)];

// Datos
import nvitacionesData from "./nvitaciones.json";

// Define the type for nvitacionInfo to include detalles
type NvitacionInfo = {
  id: string;
  precioTachado?: string | boolean; // Make precioTachado optional and accept string or boolean
  slug: string;
  muestra?: string;
  titulo?: string;
  beneficios: {
    titulo: string;
    parrafo: string;
    imaFondo: string;
  }[];
  categoria: string;
  tipo: string;
  version: string;
  imagenes: string[];
  detalles?: string; // Add detalles property
  video?: string; // Add video property
};
import BannerGeneral from "../../components/BannerGeneral.astro";
import Caracteristicas from "../../components/Caracteristicas.astro";
import Faq from "../../components/Faq.astro";

// Configuración de imágenes
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../../assets/cart/**/*.{jpg,jpeg,png,gif,webp}",
  { eager: true },
);

// Helper para verificar si es ImageMetadata
function isImageMetadata(value: any): value is ImageMetadata {
  return (
    value &&
    typeof value === "object" &&
    "src" in value &&
    "width" in value &&
    "height" in value
  );
}

// Función para cargar las imágenes del producto
async function getProductImages(nvitacionInfo: NvitacionInfo | undefined) {
  if (!product) return [];

  try {
    const imagenes = [];

    // Primero añadir la imagen de Stripe si está disponible
    if (product.data.images?.length > 0) {
      imagenes.push(product.data.images[0]);
    }

    // Luego añadir imágenes desde nvitacionInfo
    if (nvitacionInfo?.imagenes) {
      for (const imagePath of nvitacionInfo.imagenes) {
        const normalizedPath = imagePath.replace(/\\/g, "/");
        const moduleKey = Object.keys(imageModules).find((key) => {
          const keyLower = key.toLowerCase();
          const pathLower = normalizedPath.toLowerCase();
          return keyLower.endsWith(pathLower.replace("../../assets/", ""));
        });

        if (moduleKey && moduleKey in imageModules) {
          imagenes.push(imageModules[moduleKey].default);
        } else {
          console.error(`No se pudo cargar la imagen: ${imagePath}`);
        }
      }
    }

    return imagenes;
  } catch (error) {
    console.error("Error cargando imágenes:", error);
    return product.data.images || [];
  }
}

// Buscar en nvitaciones.json por slug
const nvitacionInfo: NvitacionInfo | undefined = nvitacionesData.find(
  (item) => item.slug === slug,
);

// Si no encuentra el slug, devolver 404
if (!nvitacionInfo) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

// Obtener el producto de Stripe usando el ID mapeado
const product = await getEntry("productos", nvitacionInfo.id);

// Manejo de 404: Verificar si el producto existe y está activo
if (!product || !product.data.active) {
  return new Response(null, { status: 404, statusText: "Not Found" });
}

const imagenes = await getProductImages(nvitacionInfo);

const price = await getProductPrice(product);

// Extraer símbolo de moneda y número (soporta decimales y separadores)
const match = price.match(/^([^\d]+)([\d,.]+)/);
let priceTachado = price;
if (match) {
  const currency = match[1]; // "MX$"
  // Convertir a número (eliminando comas)
  const priceNumber = Number(match[2].replace(/,/g, ""));
  const priceTachadoNumber = Math.round(priceNumber * 1.4);

  // Formatear con separador de miles y dos decimales si quieres
  const priceTachadoStr = priceTachadoNumber.toLocaleString("es-MX", {
    minimumFractionDigits: 0,
  });

  priceTachado = `${currency}${priceTachadoStr}`;
}
const productId = product.data.id;

// Calcular precio por invitado dinámicamente
const numericPrice = Number(price.replace(/,/g, "").replace(/[^\d.]/g, ""));
const costPerGuest = Math.round(numericPrice / 100);

// Meta description emocional para SEO
const metaDescription = `La invitación digital más completa para tu boda — ${price.replace(/\.00$/, "")} · ≈ $${costPerGuest} por invitado. Con música, galería animada, cuenta regresiva y confirmación en tiempo real. Personalizada a tus colores.`;
---

<Layout
  title=`${product.data.name} - Invitación Digitales para tu evento`
  description={metaDescription}
>
  <div class="grid contenido">
    <Nav />

    <div class="breadcrumb-container">
      <Breadcrumb
        categoria={nvitacionInfo?.tipo === "PDF"
          ? "pdf"
          : nvitacionInfo?.categoria?.toLowerCase()}
        nombre={product.data.name}
      />
    </div>

    <div
      id="producto-conte"
      data-category={nvitacionInfo?.categoria?.toLowerCase() ?? ""}
    >
      <div id="izq">
        <div id="fix">
          <div class="gallery-container" id="nv-gallery">
            <div class="thumbnails-container" id="nv-thumbs">
              {
                imagenes.map((imagen, index) => (
                  <div
                    class="thumbnail-wrapper"
                    role="button"
                    tabindex="0"
                    data-full-img={
                      isImageMetadata(imagen) ? imagen.src : imagen
                    }
                    data-index={index}
                    data-video-url={
                      index === 0 && nvitacionInfo?.video
                        ? nvitacionInfo.video
                        : undefined
                    }
                  >
                    {isImageMetadata(imagen) ? (
                      <Image
                        src={imagen}
                        alt={`Imagen de ${product.data.name}`}
                        height={80}
                        width={80}
                        class="thumbnail"
                        quality="max"
                      />
                    ) : (
                      <img
                        src={imagen}
                        alt={`Imagen de ${product.data.name}`}
                        height={80}
                        width={80}
                        class="thumbnail"
                      />
                    )}
                    {index === 0 && nvitacionInfo?.video && (
                      <div class="thumb-play" aria-hidden="false">
                        <Icon name="mdi:play-circle" color="white" size={28} />
                      </div>
                    )}
                  </div>
                ))
              }
            </div>

            <div
              class="main-image-container"
              id="nv-main"
              data-video-url={nvitacionInfo?.video}
            >
              <div class="media-poster">
                {
                  isImageMetadata(imagenes[0]) ? (
                    <Image
                      src={imagenes[0]}
                      loading="eager"
                      alt={product.data.name}
                      height={800}
                      width={800}
                      class="main-image"
                      id="nv-poster"
                      quality="max"
                    />
                  ) : (
                    <img
                      src={imagenes[0]}
                      loading="eager"
                      alt={product.data.name}
                      height={800}
                      width={800}
                      class="main-image"
                      id="nv-poster"
                    />
                  )
                }

                {
                  nvitacionInfo?.video && (
                    <button
                      id="nv-play"
                      class="video-play"
                      aria-label="Reproducir video"
                    >
                      <Icon name="mdi:play-circle" color="white" size={70} />
                    </button>
                  )
                }
              </div>
            </div>
          </div>
        </div>
      </div>

      <div id="der">
        <div id="titulo">
          <ul class="metadata">
            {
              nvitacionInfo && (
                <>
                  {/* {nvitacionInfo.categoria && (
                    <li>Categoría: {nvitacionInfo.categoria}</li>
                  )} */}
                  {/* {nvitacionInfo.tipo && <li>Tipo: {nvitacionInfo.tipo}</li>} */}
                  {nvitacionInfo.version && (
                    <li>Versión: {nvitacionInfo.version}</li>
                  )}
                </>
              )
            }
          </ul>
          <!-- <p>{product.data.id}</p> -->
          <h1>{product.data.name}</h1>

          <div id="conteVerNvitacion">
            <p>{product.data.description}</p>
            {
              nvitacionInfo && nvitacionInfo.muestra && (
                <>
                  <div class="liga-muestra">
                    <Btn
                      id="preview-btn"
                      liga="#"
                      texto="<b>Ver Nvitación muestra</b>"
                      icono="mdi:chevron-right"
                      clases="btn-ver-nvitaciones"
                      claro={false}
                    />
                  </div>
                  <PreviewModal url={nvitacionInfo.muestra} />
                </>
              )
            }

          </div>

        </div>

        <div class="buttons-container">
          <!-- Bloque de precio emocional — NUEVO -->
          <div class="price-block">
            <div class="price-header">
              {
                nvitacionInfo?.precioTachado && (
                  <p class="precioTachado">
                    Antes: {priceTachado}
                    <sup>.00</sup>
                  </p>
                )
              }
              <p class="main-price">
                {price.replace(/\.00$/, "")}<sup>.00</sup>
              </p>
            </div>

            <p class="price-anchor-detail">
              ≈ ${costPerGuest} por invitado para 100 personas · Sin límite de envíos
            </p>

            <Btn
              data-cart
              data-action="buy-now"
              data-productid={product.data.id}
              liga="#"
              clases="btn-claro btn-carrito"
              texto="Quiero esta invitación →"
              icono="mdi:cart-check"
              claro={true}
            />
            <!-- <p class="price-note">
              Compra ahora y personaliza tu invitación, con los colores, tipografía, música, fotos y datos de tu evento · Lista en 2 días hábiles 
            </p> -->
            <p>
              <!-- <b>Compra ahora y agenda tu invitación sin preocupaciones.</b>  -->
              Fecha estimada de entrega: {calculateDeliveryDate()}
            </p>
            <p class="price-vs">
              Imprimir 100 invitaciones: $3,200 MXN — sin música, sin galería de
              fotos, sin confirmación automática.
            </p>
          </div>

          <div class="panel-testimonial">
            {
              panelTestimonials.map((t, index) => {
                const isDefault =
                  index === getTestimonialIndex(slug, panelTestimonials.length);
                return (
                  <div
                    class="testimonial-item"
                    data-index={index}
                    style={isDefault ? "display: block;" : "display: none;"}
                  >
                    <div class="stars">
                      {Array.from({ length: t.stars }).map(() => (
                        <Icon name="solar:star-bold" class="star-icon" />
                      ))}
                    </div>
                    <p class="testimonial-text">{t.text}</p>
                    <span class="testimonial-author">{t.author}</span>
                  </div>
                );
              })
            }
          </div>
          <!-- <Btn
            data-cart
            data-action="increment"
            data-productid={product.data.id}
            liga="#"
            texto="Guardar en carrito"
            clases="btn-bordes"
            claro={false}
            icono="mdi:cart-plus"
          /> -->

          <div id="ahora"></div>

          <div id="quesucede">
            <input
              type="checkbox"
              id="quesucede-toggle"
              class="quesucede-toggle"
            />
            <label for="quesucede-toggle" class="quesucede-label"
              >¿Qué sucede después de mi compra?</label
            >
            <ul class="quesucede-content">
              <li>
                <b>Te escribimos</b> a la brevedad y te enviamos un formulario para
                recopilar las fotos y detalles de tu evento
              </li>
              <li>
                <b>Obtienes acceso</b> a tu panel de invitados para generar y gestionar
                todas tus invitaciones. <small>
                  <b>Aplica en "Clásica" y "Lux"</b>
                </small>
              </li>
              <li>
                <b>Revisas tu invitación personalizada</b> y puedes solicitar cambios
                hasta en 2 rondas de ajustes
              </li>
            </ul>
          </div>
          <a id="terminos" href="/terminos-condiciones"
            >ver terminos y condiciones</a
          >
          <SocialShare
            url={Astro.url.toString()}
            title={`Mira esta ${nvitacionInfo?.tipo || "invitación"} en Nvitaciones.com: ${product.data.name}`}
          />
        </div>

        <div id="datosjson">
          <!-- {
            nvitacionInfo.version ===
            "Esencial" ? null : nvitacionInfo.version === "Clásica" ? (
              <div class="BannerGeneralProducto">
                <BannerGeneral
                  encabezado="Confirmación de asistencia"
                  texto="¡No pierdas el control! Descubre en tiempo real quién asistirá y permite que tus invitados confirmen su asistencia <b>desde la misma invitación.</b>"
                  tema="secundario azul"
                  icono="mdi:archive-clock-outline"
                  izquierda={true}
                />

                <div id="conteCaracteristicas">
                  <Caracteristicas
                    encabezado="mapas"
                    texto="Tus invitados sabrán exactamente como llegar."
                    icono="mdi:map-check"
                    fondo="/fondo-nvite-caracteristicas.png"
                  />
                  <Caracteristicas
                    encabezado="pases"
                    texto="Mentén el control asignando pases a cada invitación."
                    icono="mdi:music-note-outline"
                    fondo="/fondo-nvite-caracteristicas.png"
                  />
                </div>
              </div>
            ) : nvitacionInfo.version === "Lux" ? (
              <div class="BannerGeneralProducto">
                <BannerGeneral
                  encabezado="Experiencia inolvidable"
                  texto="Tu invitación contará con música y mensajes personalizados, cada <b>invitación será especial</b>."
                  tema="secundario morado"
                  icono="mdi:star-outline"
                  izquierda={true}
                />

                <div id="conteCaracteristicas">
                  <Caracteristicas
                    encabezado="diseño"
                    texto="Un estilo único que se adapta a tu evento en colores, frases y tipografía."
                    icono="mdi:pencil-ruler"
                    fondo="/fondo-nvite-caracteristicas.png"
                  />
                  <Caracteristicas
                    encabezado="soporte"
                    texto="Te acompañamos en todo el proceso, desde la compra hasta que invites."
                    icono="mdi:headset"
                    fondo="/fondo-nvite-caracteristicas.png"
                  />
                </div>
              </div>
            ) : null
          } -->

          {
            nvitacionInfo && nvitacionInfo.beneficios && (
              <div class="beneficios-conte">
                {nvitacionInfo.beneficios.map((beneficio) => (
                  <BeneficioCard
                    titulo={beneficio.titulo}
                    parrafo={beneficio.parrafo}
                    imaFondo={beneficio.imaFondo}
                  />
                ))}
              </div>
            )
          }

          <!-- NUEVA sección: por qué vale lo que vale -->
          <div class="value-section">
            <h4>
              Lo que ${costPerGuest} pesos le dan a cada uno de tus invitados
            </h4>
            <ul class="value-list">
              <li>
                <b>Su nombre en la invitación</b> — no es una tarjeta masiva <span class="badge-lux"
                  >Solo Clásica y Lux</span>
              </li>
              <li>
                <b>Tu música</b> sonando cuando la abren <span class="badge-lux"
                  >Exclusivo Lux</span>
              </li>
              <li><b>Tus fotos, animadas</b>, antes de leer un solo detalle</li>
              <li>
                <b>Itinerario detallado</b> de tu evento <span class="badge-lux"
                  >Exclusivo Lux</span>
              </li>
              <li>
                <b>Mensaje personalizado</b> para invitados especiales <span
                  class="badge-lux">Exclusivo Lux</span>
              </li>
              <li><b>Confirman</b> asistencia en ese mismo momento</li>
              <li><b>Un mapa</b> que los lleva directo al lugar</li>
              <li>
                <b>Una invitación que</b> guardan en su teléfono — no en un cajón
              </li>
            </ul>
          </div>

          {
            /* Si el producto tiene "video" lo manejamos en la galería principal como poster + play */
          }
        </div>
      </div>
    </div>
  </div>

  <div class="grid contenido">
    <BannerGeneral
      encabezado="Recibes con tu <b>Nvitación</b>"
      texto={`
    <ul>
    <li><b>Trato personalizado.</b></li>
    <li>Tu invitación,<b> 2 días hábiles</b> después del envío de tus datos.</li>
    <li>
   <b>Panel de invitados</b>, controla tus invitaciones.
    </li>
    <li>
    Tu invitación disponible <b> hasta 1 semana</b> después del evento.
    </li>
    <li><mark>Envíos ilimitados.</mark></li>
       
        </ul>
        <small>*Panel de invitados exclusivo de la versión "Lux y Clásica"</small>
        <br>
        `}
      tema="secundario"
      icono="mdi:deal"
      urlImagen="../assets/home/gale/recibes.webp"
      margenAbajo={true}
    >
      <!-- <Btn
        liga="#formu"
        texto="Quiero mi ejemplo gratis →"
        clases="btn-oscuro"
        claro={true}
        blank={false}
      >
        <Icon name="bag" size={25} />
      </Btn> -->
    </BannerGeneral>
  </div>

  <Testimonios />

  <div class="grid contenido otrosProductos">
    <RelatedProducts
      currentProductId={product.id}
      category={nvitacionInfo?.categoria ||
        (product.data.metadata as Record<string, string> | undefined)
          ?.Categoria ||
        ""}
    />
  </div>

  <Faq />
  <Footer />
</Layout>

<style lang="scss">
  @use "../../estilos/variables" as *;

  #preview-btn {
    background: $acento;
    @extend .sombra;
  }
  #detalles {
    :global(h3) {
      color: $acento;
      font-size: 1.2rem;
      margin-bottom: 0.5rem;
    }
  }

  // Layout & Container styles
  .breadcrumb-container {
    margin-top: 4.5rem;
    margin-bottom: 1rem;
    @include cel {
      margin-top: 8rem;
    }
  }

  #producto-conte {
    display: grid;
    grid-template-columns: 1fr 2.5fr;
    gap: 2rem;
    align-items: stretch;

    @include cel {
      grid-template-columns: 1fr;
    }
  }

  // Left column styles
  #izq {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    position: relative;
    overflow: visible;
  }

  #fix {
    position: sticky;
    top: 4rem;
  }

  // Right column styles
  #der {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
    height: 100%;

    #titulo {
      display: grid;
      gap: 1rem;
      grid-column: 1;
      grid-row: 1;
    }

    .liga-muestra {
      display: flex;
      align-items: center;
      height: 3rem;
      border-radius: 100px;
      padding: $margen-min 0.3rem;
      width: fit-content;
      a {
        margin: 0;
        transform-origin: left;
      }
      @include cel {
        height: auto;
        padding: 0 !important;
        justify-content: center;
        border-radius: calc($radio + 0.7rem);
        a {
          width: 100%;
          text-align: center;
          transform-origin: center;
        }
      }
    }
    .buttons-container {
      grid-column: 2;
      grid-row: 1 / span 2;
      position: sticky;
      top: 4rem;
      display: grid;
      align-self: flex-start;
      background: white;
      border-radius: $radio;
      padding: calc($margen-min + 10px) $margen-min $margen-min;
      @extend .sombra;

      a {
        max-width: 100%;
      }
      a:first-child {
        margin-bottom: 1rem;
      }
      p {
        font-size: 0.8rem;
        margin: 0;
      }
    }

    @include cel {
      grid-template-columns: 1fr;
      gap: 0;
      height: auto;

      #titulo {
        grid-column: auto;
        grid-row: auto;
      }

      .buttons-container {
        position: relative;
        grid-column: auto;
        grid-row: auto;
        margin: 1.5rem 0;
      }
    }
  }
  // banner general
  .BannerGeneralProducto {
    margin: $margen 0 0 0;
  }
  // Typography styles
  h1 {
    color: $primario;
    font-size: clamp(1.7rem, 4vw, 2rem);
    border-bottom: solid 1px $primario;
    margin-bottom: $margen-cel;
  }

  //contenedor de precio
  #precio {
    display: flex;
    align-items: flex-start;
    @include cel {
      flex-direction: column;
    }
  }

  .price,
  .precioTachado {
    font-size: 1.5rem;
    font-weight: bold;
    color: $primario;
    sup {
      font-size: 0.5em;
      vertical-align: super;
    }
    @include cel {
      padding: 0 $margen-min;
    }
  }
  .precioTachado {
    font-size: 0.9rem;
    color: $acento;
    text-decoration: line-through;

    margin: 0;
  }

  // Gallery styles
  .gallery-container {
    display: flex;
    gap: 1rem;
    margin: 0 auto;
  }

  .thumbnails-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100px;
  }

  .thumbnail-wrapper {
    position: relative;
    cursor: pointer;
    border: 2px solid transparent;
    border-radius: $radio;
    overflow: hidden;
    transition: all 0.3s ease;
    display: flex;
    justify-content: center;

    &:hover {
      background: #c8c8c8;
    }

    &.active {
      border: $acento;
    }
  }

  /* Play overlay on thumbnails */
  .thumb-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 20;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.45);
    pointer-events: auto;
  }

  .thumbnail {
    width: 60%;
    height: auto;
    display: block;
    @include cel {
      width: 40%;
    }
  }

  .main-image-container {
    position: sticky;
    top: 4rem;
    height: fit-content;
    flex: 1;
    overflow: hidden;
    border-radius: 8px;

    .media-poster {
      position: relative;
      display: block;
      padding: 1rem;
      box-sizing: border-box;
    }

    .main-image {
      max-width: 100%;
      width: 100%;
      height: auto;
      display: block;
      margin: 0 auto;
      object-fit: contain;
      transition: transform 0.3s ease;
      z-index: 1;
      position: relative;
    }

    .video-play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 30;
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: auto;
      width: 84px;
      height: 84px;
      border-radius: 50%;
      background: rgba(0, 0, 0, 0.35);
      cursor: pointer;
    }
  }

  // Beneficios container styles
  .beneficios-conte {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
    gap: 1rem;

    @include cel {
      grid-template-columns: 1fr;
      margin-top: 7rem;
    }
  }

  // Metadata styles
  .metadata {
    display: flex;
    color: $acento;
    font-size: 0.8rem;
    gap: 0.7rem;
    border-top: 1px solid #e9ecef;

    li {
      list-style: none;
      margin: 0;
    }
  }

  // Video styles
  #video-home {
    width: 100%;
    max-width: 337px;
    margin: 0 auto;
    position: relative;
    border-radius: $radio;
    overflow: hidden;

    video {
      width: 100%;
      display: block;
      border-radius: $radio;
    }

    #play {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 1;
      cursor: pointer;

      svg {
        width: 70px;
        height: 70px;
        path {
          fill: $acento;
        }
      }
    }
  }

  // Utility styles
  :global(#vendidos) {
    font-size: 0.8rem;
    color: $gris;
    padding: 0.5rem 1rem;
    background-color: rgba($secundario, 0.2);
    border-radius: $radio;
    display: flex;
    align-items: center;
  }

  #terminos {
    font-size: 0.6rem;
    color: $gris;
    text-decoration: underline;
  }

  #ahora p {
    font-size: 0.8rem;
    color: $acento;
    margin-top: 1rem;

    b {
      margin-right: 0.5rem;
    }
  }

  @media (max-width: 640px) {
    .buttons-container {
      flex-direction: column;
    }
  }

  #quesucede {
    font-size: 0.9rem;
    color: $gris;
  }

  // Estilos del precio emocional
  .value-section {
    margin: 24px 0 16px;
    padding: 20px;
    background: #fdf8f4;
    border-radius: 12px;
    border: 1px solid rgba($secundario, 0.1);

    h4 {
      font-weight: 600;
      margin-bottom: 12px;
      margin-top: 0;
      color: $primario;
    }
  }

  .value-list {
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;

    li {
      list-style: none;
      color: #555;
      padding-left: 20px;
      position: relative;
      line-height: 1.5;
      text-align: left;

      &::before {
        content: "✦";
        position: absolute;
        left: 0;
        color: $acento;
        font-size: 10px;
        top: 2px;
      }
    }
  }

  .badge-lux {
    display: inline-flex;
    align-items: center;
    padding: 2px 6px;
    font-size: 9px;
    font-weight: bold;
    color: #fff;
    background: linear-gradient(135deg, #d4af37, #aa7c11);
    border-radius: 4px;
    margin-left: 6px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    vertical-align: middle;
  }

  .price-block {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 16px;
    text-align: left;
  }

  .price-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: 2px;

    .precioTachado {
      font-size: 17px !important;
      color: rgba($secundario, 0.5);
      text-decoration: line-through;
      margin: 0;
      line-height: 1.2;
      padding: 0 !important;
    }

    .main-price {
      font-size: clamp(1.6rem, 1vw, 2rem) !important;
      font-weight: 700;
      color: $primario;
      margin: 0;
      line-height: 1.2;

      sup {
        font-size: 0.5em;
        vertical-align: super;
      }
    }
  }

  .price-anchor-detail {
    font-size: 13px;
    color: #666;
    margin: 0;
    line-height: 1.3;
    font-weight: 500;
  }

  .price-vs {
    font-size: 12px;
    color: #888;
    background: #fdf8f4;
    border-left: 3px solid $acento;
    padding: 8px 12px;
    border-radius: 0 6px 6px 0;
    margin: 4px 0 8px;
    line-height: 1.5;
    text-align: left;
  }

  .price-note {
    font-size: clamp(11px, 1vw, 14px) !important;
    color: $gris;
    margin-bottom: $margen-min !important;
    line-height: 1.3;
  }

  .panel-testimonial {
    border-top: 1px solid rgba($gris, 0.2);
    padding-top: 12px;
    margin: 12px 0 0;
  }

  .panel-testimonial .stars {
    display: flex;
    gap: 2px;
    margin-bottom: 6px;

    .star-icon {
      width: 14px;
      height: 14px;
      color: $fondo;
    }
  }

  .panel-testimonial .testimonial-text {
    font-size: 12px;
    color: $gris;
    font-style: italic;
    line-height: 1.5;
    margin: 0 0 4px;
  }

  .panel-testimonial .testimonial-author {
    font-size: 0.7rem;
    color: rgba($gris, 0.75);
  }

  .btn-carrito {
    background-color: $acento !important;
    color: white !important;
    font-weight: bold;
    &:hover {
      background-color: darken($acento, 10%) !important;
    }
  }

  .quesucede-toggle {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
    pointer-events: none;
  }

  .quesucede-label {
    display: inline-block;
    color: $gris;
    font-weight: 600;
    text-decoration: underline;
    cursor: pointer;
    user-select: none;
    font-size: 0.9rem !important;
    @include cel {
      font-size: 0.8rem;
    }
  }

  .quesucede-content {
    margin-top: 0.5rem;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition:
      max-height 0.3s ease,
      opacity 0.3s ease;
  }

  .quesucede-content li {
    margin-bottom: 0.5rem;
    color: $gris;
    font-size: 0.8rem;
  }

  .quesucede-toggle:checked + .quesucede-label + .quesucede-content {
    max-height: 500px;
    opacity: 1;
  }
  .otrosProductos {
    margin-bottom: $margen;
  }

  #conteVerNvitacion{
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 1rem;
    border-radius: $radio;
    padding: $margen;
    background: rgba($terciario, 0.4);
    background:
    url("/fondo-hojas-home-white.svg") no-repeat center center / 400%,
    linear-gradient(0deg, $fondoGlobal 0%, rgba($terciario, 0.6) 50%);
   // background-blend-mode:color-dodge;
    //background-attachment: fixed;
    
    p{
      
      padding: $margen-min;
      color: $primario;
      font-weight: 600;
      border-right: 1px solid rgba($primario, 0.3);
    }
    @include cel {
      background:
      url("/fondo-hojas-home-white.svg") no-repeat center center / 1200%,
      linear-gradient(0deg, $fondoGlobal 20%, rgba($terciario, 1) 70%);
      flex-direction: column;
      padding: $margen-cel;
      p{
        border-right: none;
        border-bottom: 1px solid rgba($primario, 0.3);
        padding: $margen-cel 0;
        text-align: center;
      }
    }
  }
</style>

<script>
  import { generateRandomSales } from "../../js/utils";

  class ProductPage {
    private initialized = false;

    constructor() {
      // Inicializar cuando el documento esté listo y al navegar con Astro viewTransitions
      document.addEventListener("astro:page-load", () => {
        this.initialized = false;
        this.init();
      });
      if (document.readyState === "complete") {
        this.init();
      } else {
        document.addEventListener("DOMContentLoaded", () => this.init());
      }
    }

    init() {
      if (this.initialized) return;
      this.initialized = true;

      this.initializeSalesMessage();
      this.initializeBuyNowButtons();
      this.initializeGallery();
      this.initializePreviewModal();
      this.initializeRandomTestimonial();
    }

    // Seleccionar un testimonio aleatorio al cargar la página
    initializeRandomTestimonial() {
      const items = document.querySelectorAll(".testimonial-item");
      if (items.length === 0) return;

      // Ocultar todos
      items.forEach((item) => {
        (item as HTMLElement).style.display = "none";
      });

      // Mostrar uno aleatorio
      const randomIndex = Math.floor(Math.random() * items.length);
      (items[randomIndex] as HTMLElement).style.display = "block";
    }

    // Manejo de ventas aleatorias
    initializeSalesMessage() {
      if (document.getElementById("vendidos")) return;

      const productId = document
        .querySelector("[data-productid]")
        ?.getAttribute("data-productid");

      if (!productId) return;

      const cookieKey = `sales_${productId}`;
      const existingNumber = document.cookie
        .split(";")
        .find((c) => c.trim().startsWith(`${cookieKey}=`))
        ?.split("=")[1];

      let salesNumber = existingNumber
        ? parseInt(existingNumber)
        : generateRandomSales();

      if (!existingNumber) {
        const expires = new Date();
        expires.setDate(expires.getDate() + 7);
        document.cookie = `${cookieKey}=${salesNumber};expires=${expires.toUTCString()};path=/`;
      }

      if (salesNumber > 0) {
        const productContainer = document.getElementById("producto-conte");
        const category = (
          productContainer?.dataset?.category || ""
        ).toLowerCase();

        let subject = "parejas";
        if (category.includes("quince")) {
          subject = "quinceañeras";
        } else if (category.includes("boda") || category.includes("bodas")) {
          subject = "parejas";
        }

        const vendidosDiv = document.createElement("p");
        vendidosDiv.id = "vendidos";
        vendidosDiv.innerHTML = `<b>${salesNumber} ${subject} han confiado en esta invitación en los últimos 3 meses.</b>`;

        const conteVerNvitacion = document.getElementById("conteVerNvitacion");
        if (conteVerNvitacion?.parentNode) {
          conteVerNvitacion.insertAdjacentElement("afterend", vendidosDiv);
        } else {
          const descriptionP =
            document.querySelector("#precio + p") ||
            document.querySelector("#titulo p");
          if (descriptionP && descriptionP.parentNode) {
            descriptionP.parentNode.insertBefore(
              vendidosDiv,
              descriptionP.nextSibling,
            );
          } else {
            const precio = document.getElementById("precio");
            if (precio && precio.parentNode) {
              precio.parentNode.insertBefore(vendidosDiv, precio);
            } else {
              const titulo = document.getElementById("titulo");
              titulo?.appendChild(vendidosDiv);
            }
          }
        }
      }
    }

    // Manejo de galería de imágenes y video (implementación robusta)
    // Esta función inicializa la galería, el poster principal y el video.
    // Se destruye cualquier instancia previa para que funcione correctamente
    // con las transiciones de Astro (viewTransitions / SPA navigation).
    initializeGallery() {
      const GKEY = "__NV_GALLERY__";
      // Destroy previous instance if present (handles SPA navigation/transitions)
      try {
        (window as any)[GKEY]?.destroy?.();
      } catch (e) {
        /* ignore */
      }

      const root = document.getElementById("nv-gallery");
      if (!root) return;

      const thumbs = Array.from(
        root.querySelectorAll(".thumbnail-wrapper"),
      ) as HTMLElement[];
      const poster = document.getElementById(
        "nv-poster",
      ) as HTMLImageElement | null;
      const mainContainer = document.getElementById(
        "nv-main",
      ) as HTMLElement | null;
      const playButton = document.getElementById(
        "nv-play",
      ) as HTMLButtonElement | null;
      const mediaPoster = root.querySelector(
        ".media-poster",
      ) as HTMLElement | null;

      if (!poster || !thumbs.length || !mainContainer || !mediaPoster) return;

      const posterSrc = poster.getAttribute("src") || "";
      const videoUrl = mainContainer.getAttribute("data-video-url") || null;

      let currentIndex = 0;
      let videoEl: HTMLVideoElement | null = null;
      let videoPlayHandler:
        ((this: HTMLVideoElement, ev: Event) => any) | null = null;
      let videoPauseHandler:
        ((this: HTMLVideoElement, ev: Event) => any) | null = null;
      let videoEndedHandler:
        ((this: HTMLVideoElement, ev: Event) => any) | null = null;

      // Marca visualmente la miniatura activa.
      const setActive = (index: number) => {
        thumbs.forEach((t) => t.classList.remove("active"));
        const t = thumbs[index];
        if (t) t.classList.add("active");
      };

      const clearVideoHandlers = () => {
        if (!videoEl) return;
        if (videoPlayHandler)
          videoEl.removeEventListener("play", videoPlayHandler);
        if (videoPauseHandler)
          videoEl.removeEventListener("pause", videoPauseHandler);
        if (videoEndedHandler)
          videoEl.removeEventListener("ended", videoEndedHandler);
        videoPlayHandler = null;
        videoPauseHandler = null;
        videoEndedHandler = null;
      };

      // Detiene y limpia el elemento de video cuando cambiamos de miniatura
      // o cuando el usuario abandona el modo video.
      const destroyVideo = () => {
        if (videoEl) {
          clearVideoHandlers();
          if (playButton) playButton.style.display = "none";
          try {
            videoEl.pause();
          } catch (e) {}
          videoEl.remove();
          videoEl = null;
        }
        if (poster) poster.style.display = "";
      };

      const selectIndex = (index: number) => {
        currentIndex = index;
        const thumb = thumbs[index];
        const thumbVideo = thumb.getAttribute("data-video-url");
        const full = thumb.getAttribute("data-full-img") || posterSrc;

        // If we had a playing video, stop it
        destroyVideo();

        // If the selected thumb is the video (index 0 with video)
        if (thumbVideo) {
          // Restore poster to the original posterSrc for video
          if (poster) poster.setAttribute("src", posterSrc);
          if (playButton) playButton.style.display = "flex";
        } else {
          // Show selected image as poster
          if (poster) poster.setAttribute("src", full);
          if (playButton) playButton.style.display = "none";
        }

        setActive(index);
      };

      // Crea el elemento <video> dinámicamente y lo inserta en el poster.
      // Se vinculan eventos para mostrar/ocultar el botón Play y limpiar al finalizar.
      const createVideo = () => {
        if (!videoUrl) return;
        destroyVideo();

        videoEl = document.createElement("video");
        videoEl.src = videoUrl;
        videoEl.controls = true;
        videoEl.autoplay = true;
        videoEl.playsInline = true;
        videoEl.className = "main-image";
        videoEl.id = "nv-video";
        if (posterSrc) videoEl.setAttribute("poster", posterSrc);

        // Aplicar estilos inline al video
        videoEl.style.width = "100%";
        videoEl.style.maxWidth = "500px";
        videoEl.style.margin = "0 auto";
        videoEl.style.display = "block";
        videoEl.style.borderRadius = "10px";

        // Hide poster and append video
        if (poster) poster.style.display = "none";
        mediaPoster.appendChild(videoEl);

        // Update playButton visibility
        if (playButton) playButton.style.display = "none";

        videoPlayHandler = () => {
          if (playButton) playButton.style.display = "none";
        };
        videoPauseHandler = () => {
          if (playButton) playButton.style.display = "flex";
        };
        videoEndedHandler = () => {
          destroyVideo();
        };

        videoEl.addEventListener("play", videoPlayHandler);
        videoEl.addEventListener("pause", videoPauseHandler);
        videoEl.addEventListener("ended", videoEndedHandler);
      };

      // Handlers
      const thumbClickHandler = (e: Event) => {
        const el = e.currentTarget as HTMLElement;
        const idx = Number(el.getAttribute("data-index")) || 0;
        selectIndex(idx);
      };

      const thumbKeyHandler = (e: KeyboardEvent) => {
        if (e.key === "Enter" || e.key === " ") {
          (e.currentTarget as HTMLElement).click();
          e.preventDefault();
        }
      };

      thumbs.forEach((t) => {
        t.addEventListener("click", thumbClickHandler);
        t.addEventListener("keydown", thumbKeyHandler as any);
      });

      const playClickHandler = (e: Event) => {
        e.preventDefault();
        // Toggle if video exists
        if (videoEl) {
          if (videoEl.paused) videoEl.play().catch(() => {});
          else videoEl.pause();
          return;
        }
        createVideo();
      };

      if (playButton) {
        playButton.addEventListener("click", playClickHandler);
      }

      // expose destroy to window so SPA navigation can cleanup
      (window as any)[GKEY] = {
        destroy() {
          thumbs.forEach((t) => {
            t.removeEventListener("click", thumbClickHandler);
            t.removeEventListener("keydown", thumbKeyHandler as any);
          });
          if (playButton)
            playButton.removeEventListener("click", playClickHandler);
          destroyVideo();
          try {
            delete (window as any)[GKEY];
          } catch (e) {}
        },
      };

      // initialize
      selectIndex(0);
    }

    // Manejo de botones de compra
    initializeBuyNowButtons() {
      const buyNowButtons = document.querySelectorAll(
        '[data-action="buy-now"]',
      );
      buyNowButtons.forEach((button) =>
        button.addEventListener("click", this.handleBuyNow),
      );
    }

    private handleBuyNow(event: Event) {
      event.preventDefault();
      const button = event.currentTarget as HTMLElement;
      const productId = button.getAttribute("data-productid");
      if (!productId) return;

      const cartItems = this.getCartItemsFromCookie();
      if (!cartItems.includes(productId)) {
        cartItems.push(productId);
        document.cookie = `cartItems=${JSON.stringify(cartItems)};path=/;max-age=31536000`;
        document.dispatchEvent(new CustomEvent("cart:updated"));
      }

      window.location.href = "/nvitaciones/checkout";
    }

    private getCartItemsFromCookie(): string[] {
      const cookie = document.cookie
        .split(";")
        .find((c) => c.trim().startsWith("cartItems="))
        ?.split("=")[1];

      return cookie ? JSON.parse(cookie) : [];
    }

    // Manejo del modal de previsualización
    initializePreviewModal() {
      const previewBtn = document.getElementById("preview-btn");
      const modal = document.getElementById("preview-modal");
      const closeBtn = modal?.querySelector(".close-btn");
      const backdrop = modal?.querySelector(".modal-backdrop");

      const openModal = () => {
        // Si es dispositivo móvil (teléfono), abrir en una pestaña nueva.
        const isMobile = window.matchMedia("(max-width: 768px)").matches;
        const urlAttr = modal?.getAttribute("data-url");
        if (isMobile && urlAttr) {
          try {
            window.open(urlAttr, "_blank");
          } catch (e) {
            // Fallback: navegar en la misma pestaña
            window.location.href = urlAttr;
          }
          return;
        }

        // En tablet o escritorio, abrir en modal con iframe (comportamiento actual)
        modal?.classList.add("active");
        document.body.style.overflow = "hidden";
        modal?.dispatchEvent(new CustomEvent("modal:open"));
      };

      const closeModal = () => {
        modal?.classList.remove("active");
        document.body.style.overflow = "";
        modal?.dispatchEvent(new CustomEvent("modal:close"));
      };

      previewBtn?.addEventListener("click", (e) => {
        e.preventDefault();
        openModal();
      });

      closeBtn?.addEventListener("click", closeModal);
      backdrop?.addEventListener("click", closeModal);
    }
  }

  // Inicializar la página
  new ProductPage();
</script>
