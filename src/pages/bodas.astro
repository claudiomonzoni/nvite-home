---
export const prerender = true;
import { Icon } from "astro-icon/components";
import Btn from "../components/Btn.astro";
import Caracteristicas from "../components/Caracteristicas.astro";
import Herointerior from "../components/Herointerior.astro";
import Nav from "../components/Nav.astro";
import Layout from "../layouts/Layout.astro";
import BannerGeneral from "../components/BannerGeneral.astro";
import Footer from "../components/Footer.astro";
import CaracteristicasGrid from "../components/CaracteristicasGrid.astro";
import Banner from "../components/Banner.astro";
import SaveTheDate from "../components/SaveTheDate.astro";
import MostrarNvitaciones from "../components/Pagos/MostrarNvitaciones.astro";
---

<Layout
  title="Invitaciones Elegantes de Bodas  | RSVP y Gestión Fácil"
  description="Invitaciones de bodas digitales elegantes con confirmación de asistencia, pases, cuenta regresiva, mapas y mensajes personalizados. Lista para enviar por WhatsApp"
>
  <div class="grid contenido">
    <Nav />
  </div>

  <Herointerior
    Spanh1="<b>Invitaciones digitales</b> "
    h1="Bodas"
    Spanh2="Elegantes y únicas"
    description="Tu boda es especial, tus invitados son especiales, tus <b>invitaciones digitales</b> también lo tienen que ser"
    fondo="#e4e7ec"
    imagen="/Nvitaciones-invitaciones-digitales-bodas.webp"
    imagencel="/Nvitaciones-invitaciones-digitales-bodas-cel.webp"
    tema="claro"
    confianza="para tu gran día"
  />

  <div class="grid contenido">
    <div id="choro">
      <h2>Tu boda ya es un reto… ¿Y ahora, también las invitaciones?"</h2>

      <p>
        Con nuestras <b>invitaciones digitales de boda</b>, olvídate del caos.
        Personaliza tu diseño, gestiona invitados desde un solo panel y envía
        por WhatsApp en segundos.
      </p>
    </div>
  </div>

  <div class="grid contenido">
    <div id="conteCaracteristicas">
      <Caracteristicas
        encabezado="Administra"
        texto="Agrega, borra y edita tus invitados."
        icono="mdi:gear-outline"
        fondo="/fondo-nvite-caracteristicas-3.png"
        colorBg="#dae3ea"
      />

      <Caracteristicas
        encabezado="Envía"
        texto="Por Whatsapp, correo o redes sociales."
        icono="mdi:invoice-text-send-outline"
        fondo="/fondo-nvite-caracteristicas-2.png"
        colorBg="#fff"
        />
        
        <Caracteristicas
        encabezado="Recibe"
        texto="Confirmaciones y mensajes de tus invitados."
        icono="mdi:account-check-outline"
        fondo="/fondo-nvite-caracteristicas-4.png"
        colorBg="#dae3ea"
      />

      <Caracteristicas
        encabezado="Ilimitado"
        texto="Envía a todos tus invitados sin límite."
        icono="mdi:infinity"
        fondo="/fondo-nvite-caracteristicas-2.png"
        colorBg="#fff"
      />
    </div>
  </div>

  <!-- <section class="grid contenido">
    <p class="intro">
      Una invitación que refleje el amor y la emoción de ese día tan especial.
      En nvitaciones.com, te ayudamos a crear <b
        >invitaciones digitales únicas</b
      >, elegantes y personalizadas que dejarán una impresión inolvidable en tus
      invitados.
    </p>
  </section> -->
  <div id="nvitaciones">
    <MostrarNvitaciones dondeEstoy="bodas" />
  </div>

  



<div class="grid contenido">
  <BannerGeneral
    encabezado="Recibes con tu <b>Nvitación</b>"
    texto={`
    <ul>
    <li><b>Trato personalizado.</b></li>
    <li>Tu invitación,<b> 2 días hábiles</b> después del envío de tus datos.</li>
    <li>
   <b>Panel de invitados</b>, controla tus invitaciones.
    </li>
    <li>
    Tu invitación disponible <b> 1 semana</b> después del evento.
    </li>
    <li><mark>Envíos ilimitados.</mark></li>
       
        </ul>
        <small>*Panel de invitados no aplica en la versión "basic"</small>
        <br>
        `}
    tema="terciario"
    icono="mdi:deal"
    urlImagen="../assets/home/gale/recibes.webp"
    margenAbajo={true}
  >
    <Btn
      liga="#formu"
      texto="Obtén tu invitación"
      clases="btn-oscuro"
      claro={true}
      blank={false}
    >
      <Icon name="bag" size={25} />
    </Btn>
  </BannerGeneral>
</div>

<div id="precios" class="grid contenido">
  <Banner dondeEstoy="bodas" />
</div>

<section class="grid contenido">
  <BannerGeneral
    encabezado="Confirmación de asistencia"
    texto="Tus invitados sabrán exactamente cuántos días faltan para el evento y desde la invitación podrán <b>confirmar su asistencia</b>"
    tema="primario azul"
    icono="mdi:archive-clock-outline"
    urlImagen="../assets/home/gale/confirmacion.webp"
  >
    <Btn
      liga="/bodas"
      texto="Bodas"
      clases="btn-claro"
      claro={true}
      blank={false}
    >
      <Icon name="mdi:find-love" size={25} />
    </Btn>

    <Btn
      liga="/invitaciones-quince"
      texto="XV años"
      clases="btn-oscuro"
      claro={true}
      blank={false}
    >
      <Icon name="mdi:find-love" size={25} />
    </Btn>
  </BannerGeneral>
  <BannerGeneral
    encabezado="Invitación digital con Música"
    texto="Agrega <b>tu canción favorita</b> y los detalles de tu evento"
    tema="secundario "
    icono="mdi:music"
    izquierda={true}
    urlImagen="../assets/home/gale/musica.webp"
  />

  <BannerGeneral
    encabezado="Invitación digital con Frase de amor y galería de fotos"
    texto="Expresa con palabras lo que sientes en una <b>frase animada</b> y muestra hasta 6 fotos en una galería de imágenes"
    tema="primario"
    icono="mdi:image-plus"
    urlImagen="../assets/home/gale/frase.webp"
  />
  <!-- <BannerGeneral
      encabezado="Administra tus invitados"
      texto="De manera <b>fácil y eficiente</b>, agrega, edita, envía y controla todo desde el panel de invitados"
      tema="secundario"
      izquierda={true}
      icono="mdi:book-edit"
      urlImagen="../assets/home/gale/panel.webp"
    /> -->
  <div class="flex">
    <div class="cartaBase2">
      <h2>Invitación personalizada para cada invitado</h2>
      <p>
        Haz que tus invitados se sientan especiales desde el primer momento. <b>Cada invitación llevará el nombre del invitado o su familia,</b> creando una experiencia única y personal para tu evento."
      </p>
      <img
        id="decor"
        src="/decoracion-muestra-invitacion-digital-nvite.webp"
        alt="decoracion invitacion"
        loading="lazy"
        decoding="async"
      />
      <img
        class="imaCelular"
        src="/muestra-invitacion-digital-nvite-personalizada.webp"
        alt="invitacion personalizada"
        loading="lazy"
        decoding="async"
      />
    </div>
    <div class="cartaBase2">
      <h2>Gestiona tus pases</h2>
      <p>
        <b>Tus invitados podrán confirmar en tiempo real</b> su asistencia directamente
        desde su invitación digital, dándote tranquilidad y el control que necesitas
        para organizar tu evento."
      </p>
      <img
        src="/muestra-invitacion-digital-nvite-confirmacion-whatsapp.webp"
        alt="invitacion con confirmación de asistencia"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>

  <!-- carcateristicas -->

  <div id="conteCaracteristicas">
    <Caracteristicas
      encabezado="Invitación con mapas"
      texto="Tus invitados sabrán exactamente cómo llegar."
      icono="mdi:map-check"
      fondo="/fondo-nvite-caracteristicas.png"
    />

    <Caracteristicas
      encabezado="Invitación con mesa de regalos"
      texto="Sugiere que te gustaría de regalo."
      icono="mdi:gift-open"
      fondo="/fondo-nvite-caracteristicas-2.png"
    />

    <Caracteristicas
      encabezado="Invitación con itinerario"
      texto="Lista cada momento importante de tu evento"
      icono="mdi:gift-open"
      fondo="fondo-nvite-caracteristicas-3.png"
    />

    <!-- <Caracteristicas
        encabezado="animacón"
        texto="Agrega hasta 6 fotos."
        icono="/ico-nvite-fotos.svg"
        fondo="fondo-nvite-caracteristicas-4.png"
      /> -->
  </div>
  <Btn
    liga="#formu"
    texto="Obtén tu invitación"
    clases="btn-oscuro centrado"
    claro={false}
  />
</section>

<CaracteristicasGrid
    matriz={[
      {
        imagen: "/bodas-caracteristicas.webp",
        titulo: "Invitaciones <span>personalizadas</span>",
        texto:
          "Tus invitados sabrán lo especiales que son para ti, cada invitación se envía con su nombre y los pases asignados",
        enlace: "#precios",
      },
      {
        imagen: "mdi:email-check",
        titulo: "Confirmación de asistencia",
        texto:
          "Ten control de los asistentes a tu evento, facilítales a tus invitados su confirmación.",
        enlace: "#",
      },
      {
        imagen: "mdi:infinity-box",
        texto:
          "Invitaciones ilimitadas, envíalas a todos tus amigos y seres queridos.",
      },
      {
        imagen: "mdi:infinity-box",
        texto: "Con <span>toda la información</span> necesaria para tu boda",
      },
      {
        imagen: "mdi:infinity-box",
        texto: "<span>Cero</span> estrés por buscar a tus invitados en persona",
      },
    ]}
  />


<div class="grid contenido">
  <SaveTheDate
    h2="Save the date <span>Gratis</span>"
    p="<b>Descarga gratis tu Save the Date</b>, en formato PDF y comparte con tus seres queridos la fecha de tu boda. Personalízala online o con apps de PDF. <small><i> (Puedes usar Sedja, Illustrator o Affinity Designer) o <b>contáctanos y por $90 MXN lo editamos por ti. </b></i></small>"
    imagenes={[
      {
        imagen: "/reserva-la-fecha-1.webp",
        liga: "https://drive.google.com/file/d/1p8vFvo8Nrcfg1hc7kWKPuZelHMvTDyEW/view?usp=drive_link",
      },
      {
        imagen: "/reserva-la-fecha-2.webp",
        liga: "https://drive.google.com/file/d/17ZyXf4TW5NZvJTBz8l3n8tFrXHpDIPsI/view?usp=drive_link",
      },
      {
        imagen: "/reserva-la-fecha-3.webp",
        liga: "https://drive.google.com/file/d/1r_vCzGdy2ahv0QqYPf23KGxokH_9ncQ5/view?usp=drive_link",
      },
    ]}
  />
</div>


<section class="grid contenido" id="formulario">
  <div class="flex">
    <div class="fondo-formu">
      <div class="bande">
        <h2>Prueba tu Nvitación <br /> sin compromiso</h2>
        <p>
          <b>¿Tienes dudas o pedidos especiales?</b>, <br /> contáctanos y hagamos
          que tu invitación sea perfecta <br />😊
        </p>
      </div>

      <div id="formu">
        <form>
          <!-- <h3>
          <img src="/whatsapp.png" alt="logo whatsapp">
          <b>whatsapp</b></h3> -->

          <label for="nombre">Nombre</label>
          <input type="text" id="nombre" placeholder="Tu nombre" />
          <label for="fecha">Fecha del evento</label>
          <input type="date" name="fecha" id="fecha" />
          <label for="evento">Tipo de evento</label>
          <select name="evento" id="evento">
            <option value="Boda">Boda</option>
            <option value="Xv">XV años</option>
            <option value="Cumple">Cumpleaños</option>
          </select>

          <Btn
            liga="#"
            id="empezar"
            texto="<b>Enviar</b> ahora"
            clases="desactivado, btn-oscuro"
            claro={false}
            blank={true}
          >
            <Icon name="mdi:whatsapp" />
          </Btn>
          <!-- <button type="submit" id="empezar" class="desactivado">Empezemos</button> -->
        </form>
      </div>
    </div>
  </div>
</section>
<Footer />
</Layout>

<style lang="scss">
  @use "../estilos/_variables.scss" as *;

  .intro {
    line-height: 1.1em;
    text-align: center;
    font-size: clamp(1.3rem, 1.7vw, 2.7rem);
    margin: $margen $margen-min;
  }
  #colores {
    padding-top: $margen;
    text-align: center;
    padding-bottom: $margen;
    h2 {
      color: $primario;
      b {
        color: $acento;
      }
    }
  }
  #bandejacolor {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1rem;
    justify-content: center;
    align-items: center;
    text-align: center;
    margin-bottom: $margen-cel;
    h3 {
      color: $acento;
      padding: 0 0 $margen-min 0;
      border-bottom: dashed 0.1rem $terciario;
    }
    .item {
      padding: $margen;
      @include cel {
        padding: 0;
      }
    }
  }
</style>

<script>
  const mivideobodas = document.getElementById(
    "video-bodas-cel"
  ) as HTMLVideoElement;
  const play = document.getElementById("play") as HTMLDivElement;


  play.addEventListener("click", playPause);

  function playPause() {
    if (mivideobodas.paused) mivideobodas.play();
    else mivideobodas.pause();
  }
</script>
