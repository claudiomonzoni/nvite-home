---
import Layout from "../../layouts/panelInvitados.astro";
import Menu from "../../components/PanelInvitados/Menu.astro";
import Invitado from "../../components/PanelInvitados/Invitado.astro";
import type { InvitadoProps } from "../../components/PanelInvitados/Invitado.astro";
import AgregarInvitado from "../../components/PanelInvitados/AgregarInvitado.astro";
import EditarInvitado from "../../components/PanelInvitados/EditarInvitado.astro";
import AddonCTA from "../../components/PanelInvitados/AddonCTA.astro";
import GestorMesas from "../../components/PanelInvitados/GestorMesas.astro";
import { Usuario, Invitados, Mesas, db, eq, desc } from "astro:db";
import { Icon } from "astro-icon/components";

type MesaData = {
  id: number;
  usuarioId: number;
  nombre: string;
  capacidad: number;
};

// Ensure the user is authenticated
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect("/panel/ingresar");
}

const usuarioEmail = user.email;
const usuarioId = user.id;
const tipoInvitacion = user.tipo;
const ruta = user.ruta;
const nombreEvento = user.nombreEvento;
const fechaEvento = user.fechaEvento;
const addonMesas = user.addonMesas;

let invitadosData: InvitadoProps[] = [];
let mesasData: MesaData[] = [];

try {
  // Obtén los datos de los invitados
  invitadosData = await db
    .select()
    .from(Invitados)
    .where(eq(Invitados.usuarioId, usuarioId))
    .orderBy(desc(Invitados.id));

  // Obtén las mesas si tiene el add-on activo
  if (addonMesas) {
    mesasData = await db
      .select()
      .from(Mesas)
      .where(eq(Mesas.usuarioId, usuarioId));
  }
} catch (error) {
  console.error("Error al obtener los datos:", error);
  invitadosData = [];
  mesasData = [];
}

// Calcular estadísticas de confirmación
const totalInvitados = invitadosData.length;
const totalConfirmados = invitadosData.filter((inv) => inv.confirmado && !inv.noAsiste).length;
const porcentajeConfirmados = totalInvitados > 0 ? (totalConfirmados / totalInvitados) * 100 : 0;

const pasesPendientes = invitadosData.reduce(
  (sum, inv) =>
    !inv.confirmado && !inv.noAsiste
      ? sum + parseInt(inv.pases || "0")
      : sum,
  0
);

// Calcular días restantes y alertas dinámicas de cuenta regresiva
let diasRestantes = null;
let alertaTipo = null; // "motivacional" | "celebrativa"
let totalPendientesConfirmacion = 0;

if (fechaEvento) {
  const hoy = new Date();
  hoy.setHours(0, 0, 0, 0);
  const fechaEv = new Date(fechaEvento);
  fechaEv.setHours(0, 0, 0, 0);

  const diffTime = fechaEv.getTime() - hoy.getTime();
  diasRestantes = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

  // Contar los invitados que aún no confirman (y no han cancelado/asisten)
  totalPendientesConfirmacion = invitadosData.filter(
    (inv) => !inv.confirmado && !inv.noAsiste
  ).length;

  if (diasRestantes <= 15 && diasRestantes >= 0) {
    if (porcentajeConfirmados >= 80 || totalPendientesConfirmacion === 0) {
      alertaTipo = "celebrativa";
    } else {
      alertaTipo = "motivacional";
    }
  }
}
---

<Layout title={nombreEvento ? `Panel - ${nombreEvento}` : "Panel de Administración"}>
  <Menu tipo={tipoInvitacion} ruta={ruta} nombreEvento={nombreEvento} />
  
  <!-- Banner de Cuenta Regresiva Amigable (Alineado en el grid original) -->
  {alertaTipo && (
    <section class="grid contenido no-margin-bottom">
      <div class={`alerta-panel ${alertaTipo}`}>
        <div class="alerta-icon">
          <Icon name={alertaTipo === "celebrativa" ? "mdi:party-popper" : "mdi:calendar-heart"} size={24} />
        </div>
        <div class="alerta-mensaje">
          {alertaTipo === "celebrativa" ? (
            <span>
              <strong>¡Solo {diasRestantes} {diasRestantes === 1 ? 'día' : 'días'} para el gran día!</strong> 🎉 ¡Excelente avance! Todo está marchando de maravilla, tienes más del 80% de tus invitados confirmados. ¡A disfrutar los preparativos!
            </span>
          ) : (
            <span>
              <strong>{diasRestantes} {diasRestantes === 1 ? 'día' : 'días'} para el gran día.</strong> Aún quedan <strong>{totalPendientesConfirmacion}</strong> {totalPendientesConfirmacion === 1 ? 'invitación' : 'invitaciones'} sin confirmar y <strong>{pasesPendientes}</strong> {pasesPendientes === 1 ? 'pase libre' : 'pases libres'}. ¡Tú puedes, falta muy poco!
            </span>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Pestañas de Navegación del Panel si el Add-on está activo (Alineado en el grid original) -->
  {addonMesas && (
    <section class="grid contenido no-margin-bottom">
      <div class="tabs-container">
        <button class="tab-btn active" data-tab="invitados">
          <Icon name="mdi:account-group" size={20} />
          <span>Invitaciones</span>
        </button>
        <button class="tab-btn" data-tab="mesas">
          <Icon name="mdi:table-furniture" size={20} />
          <span>Gestión de Mesas</span>
        </button>
      </div>
    </section>
  )}

  <!-- Contenido de la pestaña INVITADOS -->
  <div
    id="tab-invitados"
    class="tab-content active"
    data-nombre-evento={nombreEvento || "Mi Evento"}
    data-fecha-evento={fechaEvento ? new Date(fechaEvento).toISOString().split('T')[0] : ""}
    data-invitados={JSON.stringify(invitadosData)}
  >
    <section class="grid contenido">
      <div id="hero">
        <div class="barra-progreso-container">
          <h3>Progreso de confirmaciones de tus invitaciones</h3>
          <div class="barra-progreso">
            <div
              class="barra"
              style={`--progress: ${
                invitadosData.length > 0
                  ? Math.round(
                      (invitadosData.filter(
                        (inv) => inv.confirmado && !inv.noAsiste
                      ).length /
                        invitadosData.length) *
                        100
                    )
                  : 0
              }%`}
            >
            </div>
          </div>
          <p class="porcentaje-texto">
            <span class="porcentaje"
              >{
                invitadosData.length > 0
                  ? Math.round(
                      (invitadosData.filter(
                        (inv) => inv.confirmado && !inv.noAsiste
                      ).length /
                        invitadosData.length) *
                        100
                    )
                  : 0
              }%</span
            > de invitaciones confirmadas,
            <span class="confirmados"
              >{
                invitadosData.reduce(
                  (sum, inv) =>
                    inv.confirmado && !inv.noAsiste
                      ? sum + parseInt(inv.pases || "0")
                      : sum,
                  0
                )
              }</span
            > pases confirmados,
            <span class="pendientes"
              >{
                invitadosData.reduce(
                  (sum, inv) =>
                    !inv.confirmado && !inv.noAsiste
                      ? sum + parseInt(inv.pases || "0")
                      : sum,
                  0
                )
              }</span
            > pases por confirmar
          </p>
        </div>
        <div class="estadisticas">
          <div class="stat-item">
            <span class="stat-numero">{invitadosData.length}</span>
            <span class="stat-label">Invitaciones creadas</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero">
              {
                invitadosData.reduce((sum, inv) => {
                  const pases = Math.round(parseFloat(inv.pases || "0"));
                  return sum + (inv.noAsiste ? 0 : pases);
                }, 0)
              }
            </span>
            <span class="stat-label">Pases asignados</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero"
              >{invitadosData.filter((inv) => inv.confirmado && !inv.noAsiste).length}</span
            >
            <span class="stat-label">Invitaciones confirmadas</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero"
              >{invitadosData.filter((inv) => inv.noAsiste).length}</span
            >
            <span class="stat-label">No asisten</span>
          </div>
          <div class="stat-item">
            <span class="stat-numero"
              >{invitadosData.filter((inv) => inv.InvitacionEnviada).length}</span
            >
            <span class="stat-label">Invitaciones enviadas</span>
          </div>
        </div>

        <div class="conteFiltros">
          <input
            id="search-input"
            type="text"
            placeholder="Buscar invitado por nombre..."
            class="buscador"
          />
          <div class="filtros">
            <div class="filtros-estado">
              <button class="filtro-btn activo" data-estado="todos">Todos</button>
              <button class="filtro-btn" data-estado="enviada">Enviada</button>
              <button class="filtro-btn" data-estado="confirmado">Confirmada</button>
              <button class="filtro-btn" data-estado="NoAsiste">No asiste</button>
              <button class="filtro-btn" data-estado="noEnviada">Falta por enviar</button>
            </div>
            <button id="btn-exportar-invitados" class="btn-excel" title="Exportar Invitados a Excel">
              <Icon name="mdi:microsoft-excel" size={18} />
              <span>Descargar Excel</span>
            </button>
          </div>
        </div>
      </div>

      <ul id="invitados-list">
        {
          invitadosData.length > 0 ? (
            invitadosData.map((invitado: InvitadoProps) => (
              <li
                class="invitado-item"
                data-nombre={invitado.nombre.toLowerCase()}
                data-estado={
                  invitado.confirmado
                    ? "confirmado"
                    : invitado.noAsiste
                      ? "NoAsiste"
                      : invitado.InvitacionEnviada
                        ? "enviada"
                        : "noEnviada"
                }
              >
                <Invitado
                  invitadoData={invitado}
                  ruta={ruta}
                  tipo={tipoInvitacion}
                />
              </li>
            ))
          ) : (
            <p>
              No tienes invitados aún. Usa el botón de abajo para agregar uno.
            </p>
          )
        }
      </ul>

      {
        usuarioId ? (
          <>
            <button id="agregar-invitado">
              <Icon name="mdi:account-plus-outline" size={25} /> Agregar invitado
            </button>
            <AgregarInvitado usuarioId={usuarioId} />
            <EditarInvitado />
          </>
        ) : (
          <>{console.error("No se encontró el ID del usuario.")}</>
        )
      }

      <!-- Banner Promo para adquirir add-on de Mesas si no lo tiene comprado -->
      {!addonMesas && (
        <div class="addon-promo-section">
          <AddonCTA
            nombre="Gestor de Mesas"
            descripcion="Distribuye tus invitados en mesas numeradas, calcula espacios libres y controla la capacidad en tiempo real desde tu celular."
            icono="mdi:table-furniture"
          />
        </div>
      )}
    </section>
  </div>

  <!-- Contenido de la pestaña GESTIÓN DE MESAS -->
  {addonMesas && (
    <div id="tab-mesas" class="tab-content">
      <section class="grid contenido">
        <GestorMesas mesas={mesasData} invitados={invitadosData} nombreEvento={nombreEvento} fechaEvento={fechaEvento} />
      </section>
    </div>
  )}
</Layout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // 1. Funcionalidad de pestañas (tabs) con persistencia en localStorage
    const tabBtns = document.querySelectorAll(".tab-btn");
    const tabContents = document.querySelectorAll(".tab-content");

    const switchTab = (targetTab: string) => {
      tabBtns.forEach((b) => {
        if (b.getAttribute("data-tab") === targetTab) {
          b.classList.add("active");
          b.classList.add("activo");
        } else {
          b.classList.remove("active");
          b.classList.remove("activo");
        }
      });
      tabContents.forEach((c) => {
        if (c.id === `tab-${targetTab}`) {
          c.classList.add("active");
        } else {
          c.classList.remove("active");
        }
      });
      localStorage.setItem("panelActiveTab", targetTab);
    };

    tabBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const targetTab = btn.getAttribute("data-tab");
        if (targetTab) {
          switchTab(targetTab);
        }
      });
    });

    // Restaurar pestaña activa tras recarga
    const savedTab = localStorage.getItem("panelActiveTab");
    if (savedTab && document.getElementById(`tab-${savedTab}`)) {
      switchTab(savedTab);
    }

    // 2. Funcionalidad del buscador y filtros
    const searchInput = document.getElementById("search-input") as HTMLInputElement;
    const invitadosList = document.getElementById("invitados-list");
    
    if (searchInput && invitadosList) {
      const invitadoItems = invitadosList.querySelectorAll(".invitado-item") as NodeListOf<HTMLLIElement>;
      const filtroBtns = document.querySelectorAll(".filtro-btn") as NodeListOf<HTMLButtonElement>;

      let estadoFiltro = "todos";

      const filtrarInvitados = () => {
        const searchTerm = searchInput.value.toLowerCase().trim();

        invitadoItems.forEach((item) => {
          const nombre = item.getAttribute("data-nombre") || "";
          const estado = item.getAttribute("data-estado") || "";

          const cumpleBusqueda = nombre.includes(searchTerm);
          const cumpleFiltro = estadoFiltro === "todos" || estado === estadoFiltro;

          item.style.display = cumpleBusqueda && cumpleFiltro ? "block" : "none";
        });
      };

      searchInput.addEventListener("input", filtrarInvitados);

      filtroBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
          filtroBtns.forEach((b) => {
            b.classList.remove("activo");
            b.classList.remove("active");
          });
          btn.classList.add("activo");
          btn.classList.add("active");
          estadoFiltro = btn.getAttribute("data-estado") || "todos";
          filtrarInvitados();
        });
      });
    }

    // 3. Exportar a Excel (SheetJS)
    const loadSheetJS = () => {
      return new Promise<void>((resolve, reject) => {
        if ((window as any).XLSX) {
          resolve();
          return;
        }
        const script = document.createElement("script");
        script.src = "https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js";
        script.onload = () => resolve();
        script.onerror = () => reject(new Error("No se pudo cargar la librería de Excel."));
        document.head.appendChild(script);
      });
    };

    const btnExportar = document.getElementById("btn-exportar-invitados") as HTMLButtonElement | null;
    btnExportar?.addEventListener("click", async () => {
      if (!btnExportar) return;
      try {
        btnExportar.disabled = true;
        const originalText = btnExportar.innerHTML;
        btnExportar.innerHTML = "<span>Generando...</span>";
        
        await loadSheetJS();
        
        const tabInvitados = document.getElementById("tab-invitados");
        const invitados = JSON.parse(tabInvitados?.getAttribute("data-invitados") || "[]");
        const nombreEvento = tabInvitados?.getAttribute("data-nombre-evento") || "evento";
        const fechaEvento = tabInvitados?.getAttribute("data-fecha-evento") || "";
        
        interface ExportRow {
          Nombre: string;
          Pases: number;
          Estado: string;
          Tipo: string;
          WhatsApp: string;
          "Invitación Enviada": string;
          "Invitado VIP": string;
          Mesa: string;
        }
        
        const formattedData: ExportRow[] = invitados.map((inv: any) => {
          let estado = "Sin confirmar";
          if (inv.noAsiste) estado = "No asiste";
          else if (inv.confirmado) estado = "Confirmado";
          
          return {
            Nombre: String(inv.nombre || ""),
            Pases: parseInt(String(inv.pases || "0"), 10),
            Estado: estado,
            Tipo: String(inv.tipoInvitacion || "Familiar"),
            WhatsApp: String(inv.numeroWhats || "Sin registrar"),
            "Invitación Enviada": inv.InvitacionEnviada ? "Sí" : "No",
            "Invitado VIP": inv.vip ? "Sí" : "No",
            Mesa: String(inv.mesa || "Sin asignar")
          };
        });
        
        // Ordenar: mesas agrupadas, al final Sin asignar
        formattedData.sort((a, b) => {
          if (a.Mesa !== "Sin asignar" && b.Mesa === "Sin asignar") return -1;
          if (a.Mesa === "Sin asignar" && b.Mesa !== "Sin asignar") return 1;
          if (a.Mesa !== "Sin asignar" && b.Mesa !== "Sin asignar") {
            return a.Mesa.localeCompare(b.Mesa);
          }
          return a.Nombre.localeCompare(b.Nombre);
        });
        
        const XLSX = (window as any).XLSX;
        const worksheet = XLSX.utils.json_to_sheet(formattedData);
        const workbook = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(workbook, worksheet, "Invitados");
        
        // Ajustar ancho de columnas automáticamente
        const maxLen = formattedData.reduce((acc, row) => {
          acc.Nombre = Math.max(acc.Nombre, row.Nombre.length);
          acc.Estado = Math.max(acc.Estado, row.Estado.length);
          acc.Tipo = Math.max(acc.Tipo, row.Tipo.length);
          acc.WhatsApp = Math.max(acc.WhatsApp, row.WhatsApp.toString().length);
          acc.Mesa = Math.max(acc.Mesa, row.Mesa.length);
          return acc;
        }, { Nombre: 10, Pases: 6, Estado: 15, Tipo: 12, WhatsApp: 15, Mesa: 15 });
        
        worksheet["!cols"] = [
          { wch: maxLen.Nombre + 3 },
          { wch: 10 },
          { wch: maxLen.Estado + 3 },
          { wch: maxLen.Tipo + 3 },
          { wch: maxLen.WhatsApp + 3 },
          { wch: 20 },
          { wch: 15 },
          { wch: maxLen.Mesa + 3 }
        ];
        
        const sanitizedNombre = nombreEvento.toLowerCase().replace(/[^a-z0-9]/g, "-").replace(/-+/g, "-").replace(/^-|-$/g, "");
        const fileName = `invitados-${sanitizedNombre}-${fechaEvento || new Date().toISOString().split("T")[0]}.xlsx`;
        
        XLSX.writeFile(workbook, fileName);
        
        btnExportar.innerHTML = originalText;
        btnExportar.disabled = false;
      } catch (err) {
        console.error(err);
        alert("Ocurrió un error al descargar el Excel.");
        btnExportar.innerHTML = "<span>Descargar Excel</span>";
        btnExportar.disabled = false;
      }
    });
  });
</script>

<style lang="scss">
  @use "../../estilos/_variables.scss" as *;

  .no-margin-bottom {
    padding-bottom: 0 !important;
    margin-bottom: 0 !important;
  }

  .tabs-container {
    grid-column: contenido;
    display: flex;
    gap: 0.5rem;
    border-bottom: 2px solid #e5e7eb;
    padding-bottom: 0.1rem;
    margin-bottom: 1rem;

    .tab-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: transparent;
      border: none;
      padding: 0.75rem 1.5rem;
      font-size: 1rem;
      font-weight: 500;
      color: $gris;
      cursor: pointer;
      border-radius: 8px 8px 0 0;
      position: relative;
      transition: all 0.2s ease;
      @include cel{
        flex-direction: column;
      }

      &:hover {
        color: $primario;
        background-color: rgba($primario, 0.03);
      }

      &.active {
        color: $acento;
        font-weight: bold;

        &::after {
          content: "";
          position: absolute;
          bottom: -0.2rem;
          left: 0;
          right: 0;
          height: 3px;
          background-color: $acento;
          border-radius: 2px;
        }
      }
    }
  }

  .tab-content {
    display: none;

    &.active {
      display: block;
    }
  }

  .alerta-panel {
    grid-column: contenido;
    display: flex;
    gap: 1rem;
    align-items: center;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.02);
    font-size: 0.95rem;
    line-height: 1.5;
    margin-top: 1rem;

    .alerta-icon {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    &.motivacional {
      background-color: #fffbeb;
      color: #92400e;
      border: 1px solid #fef3c7;
      .alerta-icon { color: #d97706; }
    }

    &.celebrativa {
      background-color: #f0fdf4;
      color: #166534;
      border: 1px solid #dcfce7;
      .alerta-icon { color: #22c55e; }
    }
  }

  .addon-promo-section {
    grid-column: contenido;
    margin-top: 3rem;
    border-top: 1px dashed #e5e7eb;
    padding-top: 2rem;
  }

  #hero {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    padding-bottom: $margen-min;

    @include cel {
      gap: 0.5rem;
    }

    h1 {
      flex: 1 0 auto;
      font-size: clamp(2.2rem, 2.4vw, 4rem);
      color: $primario;
      width: fit-content;
    }
  }

  .buscador {
    padding: 0.5rem;
    border-radius: 5px;
    font-size: 1rem;
    flex: 1 0 auto;
    box-shadow: none; 
    background-color: rgba($terciario, 0.5);

    @include cel {
      margin: $margen-min 0;
    }
  }

  .conteFiltros {
    width: 100%;
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: solid 1px #ccc;
    padding-bottom: $margen-min;
    flex-wrap: wrap;
    gap: 1rem;
    align-items: center;

    @include cel {
      grid-template-columns: 1fr;
    }
  }

  #invitados-list {
    display: grid;
       grid-template-columns: repeat(auto-fill, minmax(370px, 1fr));
    gap: 1rem;
    .invitado-item {
      flex: 1 1 30%;
      list-style: none;
      margin-left: 0!important;
    }

    @include cel {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }

    @include tableta {
      grid-template-columns: 1fr 1fr;
    }
  }

  .stat-item {
    flex: 1;
    display: flex;
    min-width: 150px;
    text-align: center;
    justify-content: center;
    padding: 1rem;
    border-right: 1px solid rgba($primario, 0.1);
    justify-content: center;
    align-items: center;
    font-size: clamp(0.9rem, 1vw, 1rem);
    gap: 1rem;
    
    .stat-numero {
      font-size: clamp(1.3rem, 1.5vw, 1.5rem);
      color: $secundario;
      font-weight: bold;
    }

    &:last-child {
      border-right: none;
    }

    @include cel {
      min-width: calc(50% - 1rem);
      padding: .5rem 0.2rem;
      border-right: none;
      border-bottom: 1px solid rgba($primario, 0.1);
      gap:.5rem;
      flex-direction: column;
      &:nth-last-child(-n + 2) {
        border-bottom: none;
      }
    }
  }

  .filtros {
    display: flex;
    width: 100%;
    flex: 1 0 auto;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    
    @include cel {
      order: 1;
    }
    input {
      border-radius: $radio;
    }
  }

  .filtros-estado {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filtro-btn {
    flex: 1 0 auto;
    padding: 0.5rem 1rem;
    border: 1px solid $primario;
    border-radius: $radio;
    background: transparent;
    color: $primario;
    max-width: fit-content;
    cursor: pointer;
    transition: all 0.3s ease;

    &:hover {
      background: rgba($primario, 0.1);
    }

    &.activo, &.active {
      background: $secundario;
      color: white;
      border: 1px solid $secundario;
    }
  }

  .btn-excel {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border: 1px solid #bbf7d0;
    border-radius: $radio;
    background-color: #f0fdf4;
    color: #166534;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;

    &:hover {
      background-color: #dcfce7;
      transform: translateY(-1px);
    }

    &:active {
      transform: translateY(0);
    }

    &[disabled] {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }
  }

  .estadisticas {
    display: flex;
    gap: 2rem;
    width: 100%;
    padding: 1rem;
    background: white;
    border-radius: $radio;
    flex-wrap: wrap;
    @extend .sombra;

    @include cel {
      gap: 1rem;
      padding: 0.5rem;
    }
  }

  .barra-progreso-container {
    width: 100%;

    h3 {
      color: $primario;
      margin-bottom: 1rem;
      font-size: 1.2rem;
    }
  }

  .barra-progreso {
    width: 100%;
    height: 5px;
    background-color: #f0f0f0;
    border-radius: 10px;
    overflow: hidden;
    margin: 0.5rem 0;
  }

  .barra {
    height: 100%;
    width: 0;
    background: linear-gradient(to right, $terciario, $secundario);
    animation: crecer 1.5s ease-out forwards;
  }

  @keyframes crecer {
    from {
      width: 0;
    }
    to {
      width: var(--progress);
    }
  }

  .porcentaje-texto {
    font-size: 1.1rem;
    color: $primario;
    margin-top: 0.5rem;
    line-height: 1.5;

    .porcentaje {
      font-size: 1.3rem;
      font-weight: bold;
    }

    .confirmados,
    .pendientes {
      font-weight: bold;
    }
  }

  #agregar-invitado {
    background-color: $acento;
    border-radius: $radio;
    color: #fff;
    border: none;
    display: inline-block;
    text-align: center;
    padding: 0.5rem 1rem;
    font-size: clamp(1.1rem, 1rem, 2rem);
    font-weight: bold;
    margin: 1rem 0;
    position: fixed;
    right: 5%;
    bottom: 2%;
    z-index: 99;
    @extend .sombra;
    
    svg {
      vertical-align: middle;
      margin-right: 0.2rem;
    }
  }
</style>
